<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Purchase Form View -->
        <record id="view_havanoposdesk_purchase_form" model="ir.ui.view">
            <field name="name">havanoposdesk.purchase.form</field>
            <field name="model">havanoposdesk.purchase</field>
            <field name="arch" type="xml">
                <form string="Purchase">
                    <header>
                        <button name="action_post" string="Confirm" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                        <button name="action_cancel" string="Cancel" type="object" invisible="state != 'posted'"/>
                        <button name="action_draft" string="Reset to Draft" type="object" invisible="state != 'cancelled'"/>
                        <button name="%(action_havanoposdesk_purchase_return_wizard)d" string="Debit Note" type="action" class="btn-primary" invisible="state != 'posted' or is_return"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,posted"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name"/>
                            </h1>
                            <h2>
                                <span invisible="not is_return" class="text-danger">Debit Note</span>
                            </h2>
                        </div>
                        <group>
                            <group>
                                <field name="currency_id" invisible="1"/>
                                <field name="is_tax_enabled" invisible="1"/>
                                <field name="invoice_type" readonly="1" class="border-bottom border-dark"/>
                                <field name="supplier" readonly="state != 'draft'" class="border-bottom border-dark"/>
                                <field name="store_id" options="{'no_create': True}" readonly="state != 'draft'" class="border-bottom border-dark"/>
                                <field name="is_return" invisible="1"/>
                                <field name="return_id" invisible="not is_return" readonly="1" class="border-bottom border-dark"/>
                            </group>
                            <group>
                                <field name="posting_date" readonly="state != 'draft'" class="border-bottom border-dark"/>
                                <field name="posting_time" widget="float_time" readonly="state != 'draft'" class="border-bottom border-dark"/>
                                <field name="payment_status" readonly="state != 'draft'" class="border-bottom border-dark" widget="radio" options="{'horizontal': true}"/>
                                <field name="account_id" invisible="payment_status != 'cash'" required="payment_status == 'cash'" readonly="state != 'draft'" options="{'no_create': True, 'no_open': True}" class="border-bottom border-dark"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Items">
                                <field name="line_ids" readonly="state != 'draft'">
                                    <list  editable="bottom">
                                        <field name="currency_id" column_invisible="True"/>
                                        <field name="product_id" domain="[('store_id', '=', parent.store_id)]" width="25%" optional="show"/>
                                        <field name="item_code" width="10%" optional="show"/>
                                        <field name="accepted_qty" width="15%" sum="Total Qty" optional="show"/>
                                        <field name="rate" width="15%" optional="show" widget="monetary"/>
                                        <field name="tax_ids" widget="many2many_tags" width="15%" optional="show" column_invisible="parent.is_tax_enabled == False"/>
                                        <field name="price_tax" string="Tax Amount" width="10%" sum="Total Tax" optional="show" widget="monetary" column_invisible="parent.is_tax_enabled == False"/>
                                        <field name="amount" width="10%" sum="Total Amount" optional="show" widget="monetary"/>
                                    </list>
                                </field>
                                <group class="oe_subtotal_footer oe_right" colspan="2" name="purchase_total">
                                    <field name="amount_untaxed" widget="monetary" string="Total Excl" invisible="not is_tax_enabled"/>
                                    <field name="amount_tax" widget="monetary" string="Total Tax" invisible="not is_tax_enabled"/>
                                    <field name="amount_total" class="oe_subtotal_footer_separator" widget="monetary" string="Total Incl"/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Purchase Tree View -->
        <record id="view_havanoposdesk_purchase_tree" model="ir.ui.view">
            <field name="name">havanoposdesk.purchase.tree</field>
            <field name="model">havanoposdesk.purchase</field>
            <field name="arch" type="xml">
                <list  string="Purchases">
                    <field name="currency_id" column_invisible="True"/>
                    <field name="is_tax_enabled" column_invisible="True"/>
                    <field  name="name" optional="show"/>
                    <field  name="invoice_type" optional="show" readonly="1" string="Type"/>
                    <field  name="payment_status" optional="show"/>
                    <field  name="supplier" optional="show"/>
                    <field  name="store_id" optional="show"/>
                    <field  name="posting_date" optional="show"/>
                    <field  name="posting_time" widget="float_time" optional="show"/>
                    <field name="amount_untaxed" string="Total Exclu" sum="Total Exclu" widget="monetary" column_invisible="not is_tax_enabled"/>
                    <field name="amount_tax" string="Total Tax" sum="Total Tax" widget="monetary" column_invisible="not is_tax_enabled"/>
                    <field name="amount_total" string="Total Inclu" sum="Total Inclu" widget="monetary"/>
                    <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'posted'" decoration-danger="state == 'cancelled'" optional="show"/>
                </list>
            </field>
        </record>

        <!-- Action -->
        <record id="action_havanoposdesk_purchase" model="ir.actions.act_window">
            <field name="name">Purchases</field>
            <field name="res_model">havanoposdesk.purchase</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new Purchase Record
                </p>
            </field>
        </record>

        <!-- Menu -->
        <menuitem id="menu_suppliers_purchase" 
                  name="Purchases" 
                  parent="menu_suppliers_operations" 
                  action="action_havanoposdesk_purchase" 
                  sequence="10"/>
    </data>
</odoo>
