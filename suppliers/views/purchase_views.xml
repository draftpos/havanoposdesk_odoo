<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Purchase Form View -->
        <record id="view_havanoposdesk_purchase_form" model="ir.ui.view">
            <field name="name">havanoposdesk.purchase.form</field>
            <field name="model">havanoposdesk.purchase</field>
            <field name="arch" type="xml">
                <form string="Purchase">
                    <sheet>
                        <div class="oe_title" invisible="1">
                            <h1>
                                <field name="name"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="supplier" class="border-bottom border-dark"/>
                                <field name="store_id" options="{'no_create': True}" class="border-bottom border-dark"/>
                            </group>
                            <group>
                                <field name="posting_date" class="border-bottom border-dark"/>
                                <field name="posting_time" widget="float_time" class="border-bottom border-dark"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Items">
                                <field name="line_ids">
                                    <list  editable="bottom">
                                        <field name="item_code" width="15%" optional="show"/>
                                        <field name="product_id" domain="[('store_id', '=', parent.store_id)]" width="25%" optional="show"/>
                                        <field name="accepted_qty" width="25%" sum="Total Qty" optional="show"/>
                                        <field name="rate" width="25%" optional="show"/>
                                        <field name="amount" width="25%" sum="Total Amount" optional="show"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Purchase Tree View -->
        <record id="view_havanoposdesk_purchase_tree" model="ir.ui.view">
            <field name="name">havanoposdesk.purchase.tree</field>
            <field name="model">havanoposdesk.purchase</field>
            <field name="arch" type="xml">
                <list  string="Purchases">
                    <field  name="name" optional="show"/>
                    <field  name="supplier" optional="show"/>
                    <field  name="store_id" optional="show"/>
                    <field  name="posting_date" optional="show"/>
                    <field  name="posting_time" widget="float_time" optional="show"/>
                </list>
            </field>
        </record>

        <!-- Action -->
        <record id="action_havanoposdesk_purchase" model="ir.actions.act_window">
            <field name="name">Purchases</field>
            <field name="res_model">havanoposdesk.purchase</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new Purchase Record
                </p>
            </field>
        </record>

        <!-- Menu -->
        <menuitem id="menu_suppliers_purchase" 
                  name="Purchases" 
                  parent="menu_suppliers_master" 
                  action="action_havanoposdesk_purchase" 
                  sequence="10"/>
    </data>
</odoo>
