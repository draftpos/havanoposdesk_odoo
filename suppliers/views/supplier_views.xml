<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Supplier Form View -->
        <record id="view_havanoposdesk_supplier_form" model="ir.ui.view">
            <field name="name">havanoposdesk.supplier.form</field>
            <field name="model">havanoposdesk.supplier</field>
            <field name="arch" type="xml">
                <form string="Supplier">
                    <sheet>
                        <group>
                            <group>
                                <field name="name" class="border-bottom border-dark"/>
                                <field name="phone" class="border-bottom border-dark"/>
                                <field name="store_id" domain="[('tenant_id', '=', tenant_id)]" options="{'no_create': True}" class="border-bottom border-dark"/>
                                <field name="tenant_id" invisible="1"/>
                            </group>
                            <group>
                                <field name="address" class="border-bottom border-dark"/>
                                <field name="email" class="border-bottom border-dark"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Supplier Tree View -->
        <record id="view_havanoposdesk_supplier_tree" model="ir.ui.view">
            <field name="name">havanoposdesk.supplier.tree</field>
            <field name="model">havanoposdesk.supplier</field>
            <field name="arch" type="xml">
                <list  string="Suppliers">
                    <field name="name" optional="show"/>
                    <field name="phone" optional="show"/>
                    <field name="email" optional="show"/>
                </list>
            </field>
        </record>

        <!-- Action -->
        <record id="action_havanoposdesk_supplier" model="ir.actions.act_window">
            <field name="name">Suppliers</field>
            <field name="res_model">havanoposdesk.supplier</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new Supplier Record
                </p>
            </field>
        </record>

        <!-- Menu -->
        <menuitem id="menu_suppliers_supplier" 
                  name="Suppliers" 
                  parent="menu_suppliers_master" 
                  action="action_havanoposdesk_supplier" 
                  sequence="20"/>
    </data>
</odoo>