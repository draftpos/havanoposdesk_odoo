<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_users_form_inherit_havano" model="ir.ui.view">
            <field name="name">res.users.form.inherit.havano</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_form"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="inside">
                    <page string="Havano SaaS" name="havano_saas">
                        <group>
                            <group string="SaaS Credentials">
                                <field name="havano_role"/>
                                <field name="tenant_id" options="{'no_create': True}" invisible="havano_role == 'super_admin'"/>
                            </group>
                            <group string="Email Verification" invisible="havano_role == 'super_admin'">
                                <field name="verification_token" readonly="1"/>
                                <field name="verification_sent_at" readonly="1"/>
                            </group>
                            <group string="Store Access" invisible="havano_role == 'super_admin'">
                                <field name="default_store_id" domain="[('tenant_id', '=', tenant_id)]" options="{'no_create': True}"/>
                                <field name="store_ids" widget="many2many_tags" domain="[('tenant_id', '=', tenant_id)]" options="{'no_create': True}"/>
                            </group>
                            <group string="API &amp; Integration Settings">
                                <field name="api_company_name"/>
                                <field name="api_currency"/>
                                <field name="api_cost_center" placeholder="Defaults to default store if blank"/>
                                <field name="api_warehouse" placeholder="Defaults to default store if blank"/>
                            </group>
                            <group string="POS Settings">
                                <field name="allow_discount"/>
                                <field name="max_discount_percent"/>
                                <field name="require_shift"/>
                            </group>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
