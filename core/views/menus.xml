<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Enable Free Sign Up (B2C Registration) by default -->
        <!-- Removed config parameters to prevent UniqueViolation error on module upgrade -->

        <!-- Top-level Menus acting as Apps on the Dashboard -->
        <menuitem id="menu_inventory_root" name="Stock" sequence="10" web_icon="havanoposdesk_odoo,static/description/stock.png"/>
        <menuitem id="menu_sales_root" name="Sales" sequence="20" web_icon="havanoposdesk_odoo,static/description/sales.png"/>
        <menuitem id="menu_suppliers_root" name="Suppliers" sequence="30" web_icon="havanoposdesk_odoo,static/description/purchases.png" action="action_havanoposdesk_purchase"/>
        <menuitem id="menu_accounts_root" name="Accounts" sequence="40" web_icon="havanoposdesk_odoo,static/description/accounts.png"/>
        <menuitem id="menu_dashboard_main" name="Dashboard" sequence="5" web_icon="board,static/description/icon.png" action="action_havano_dashboard_client"/>

        <!-- Stock Navigation Tabs -->
        <menuitem id="menu_inventory_master" name="Master" parent="menu_inventory_root" sequence="10"/>
        <menuitem id="menu_inventory_operations" name="Operations" parent="menu_inventory_root" sequence="20"/>
        <menuitem id="menu_inventory_reports" name="Reports" parent="menu_inventory_root" sequence="30"/>
        <!-- Sales Navigation Tabs -->
        <menuitem id="menu_sales_master" name="Master" parent="menu_sales_root" sequence="10"/>
        <menuitem id="menu_sales_operations" name="Operations" parent="menu_sales_root" sequence="20"/>
        <menuitem id="menu_sales_reports" name="Reports" parent="menu_sales_root" sequence="30"/>

        <!-- Suppliers Navigation Tabs -->
        <menuitem id="menu_suppliers_master" name="Master" parent="menu_suppliers_root" sequence="10"/>
        <menuitem id="menu_suppliers_operations" name="Operations" parent="menu_suppliers_root" sequence="20"/>
        <menuitem id="menu_suppliers_reports" name="Reports" parent="menu_suppliers_root" sequence="30"/>

        <!-- Accounts Navigation Tabs -->
        <menuitem id="menu_accounts_master" name="Master" parent="menu_accounts_root" sequence="10"/>
        <menuitem id="menu_accounts_operations" name="Operations" parent="menu_accounts_root" sequence="20"/>
        <menuitem id="menu_accounts_reports" name="Reports" parent="menu_accounts_root" sequence="30"/>

        <!-- Profit and Loss Client Action -->
        <record id="action_havanoposdesk_profit_and_loss" model="ir.actions.client">
            <field name="name">Profit and Loss</field>
            <field name="tag">havanoposdesk_profit_and_loss</field>
        </record>
        <menuitem id="menu_accounts_profit_and_loss" name="Profit and Loss" parent="menu_accounts_reports" action="action_havanoposdesk_profit_and_loss" sequence="10" groups="havanoposdesk_odoo.group_tenant_admin,base.group_system"/>

        <!-- Actions -->
        <record id="action_havanoposdesk_tenant" model="ir.actions.act_window">
            <field name="name">Tenants</field>
            <field name="res_model">havanoposdesk.tenant</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- SaaS Configuration App (Restricted to Settings Administrator) -->
        <menuitem id="menu_saas_root" name="SaaS Config" sequence="5" web_icon="havanoposdesk_odoo,static/description/saas_config.png" groups="base.group_system"/>

        <!-- Override Odoo Apps Menu with correct name and icon -->
        <menuitem id="base.menu_management" name="Apps" web_icon="havanoposdesk_odoo,static/description/apps.png"/>

        <!-- SaaS Admin Navigation -->
        <menuitem id="menu_saas_users" name="Users" parent="menu_saas_root" action="action_saas_users" sequence="10"/>
        <menuitem id="menu_saas_tenants" name="Tenants" parent="menu_saas_root" action="action_havanoposdesk_tenant" sequence="20"/>
        <menuitem id="menu_saas_stores" name="Stores" parent="menu_saas_root" action="action_havanoposdesk_store" sequence="30"/>
        <menuitem id="menu_saas_plans" name="Subscription Plans" parent="menu_saas_root" action="action_subscription_plans" sequence="40"/>
        <menuitem id="menu_saas_payment_providers" name="Payment Providers" parent="menu_saas_root" action="payment.action_payment_provider" sequence="50"/>
        
        <!-- Also keep Tenants and Stores in native users menu just in case -->
        <menuitem id="menu_tenant" name="Tenants" parent="base.menu_users" action="action_havanoposdesk_tenant" sequence="100"/>
        <menuitem id="menu_store" name="Stores" parent="base.menu_users" action="action_havanoposdesk_store" sequence="110"/>

        <!-- Action: Purchases Analytics fallback -->
        <record id="action_purchases_analysis" model="ir.actions.act_window">
            <field name="name">Purchases Analysis</field>
            <field name="res_model">havanoposdesk.purchase</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Purchases Analysis
                </p>
            </field>
        </record>


    </data>
</odoo>

