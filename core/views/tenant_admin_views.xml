<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>
        
        <menuitem id="menu_my_business_root" name="My Business" sequence="5" web_icon="havanoposdesk_odoo,static/description/mybusiness.png" groups="base.group_user" />

        
        <menuitem id="menu_tenant_admin_settings_root" name="Configs" web_icon="havanoposdesk_odoo,static/description/configs.png" sequence="550" groups="havanoposdesk_odoo.group_tenant_admin,base.group_system" action="action_havanoposdesk_settings_my_business" />

        
        <record id="action_my_stores" model="ir.actions.act_window">
            <field name="name">My Stores</field>
            <field name="res_model">havanoposdesk.store</field>
            <field name="view_mode">list,form</field>
        </record>
        <menuitem id="menu_my_stores" name="Stores" parent="menu_my_business_root" action="action_my_stores" sequence="10" />

        
        <record id="action_my_terminals" model="ir.actions.act_window">
            <field name="name">My POS Terminals</field>
            <field name="res_model">havanoposdesk.pos.terminal</field>
            <field name="view_mode">list,form</field>
        </record>
        <menuitem id="menu_my_terminals" name="POS Terminals" parent="menu_my_business_root" action="action_my_terminals" sequence="20" />

        
        <record id="view_havano_change_password_wizard_form" model="ir.ui.view">
            <field name="name">havano.change.password.wizard.form</field>
            <field name="model">havano.change.password.wizard</field>
            <field name="arch" type="xml">
                <form string="Change Cashier Password">
                    <group>
                        <field name="user_id" readonly="1" force_save="1" />
                        <field name="new_password" password="True" required="1" />
                    </group>
                    <footer>
                        <button name="action_change_password" string="Change Password" type="object" class="btn-primary" />
                        <button string="Cancel" class="btn-secondary" special="cancel" />
                    </footer>
                </form>
            </field>
        </record>

        
        <record id="action_havano_change_password_wizard" model="ir.actions.act_window">
            <field name="name">Change Password</field>
            <field name="res_model">havano.change.password.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        
        <record id="view_havano_change_pin_wizard_form" model="ir.ui.view">
            <field name="name">havano.change.pin.wizard.form</field>
            <field name="model">havano.change.pin.wizard</field>
            <field name="arch" type="xml">
                <form string="Change My PIN">
                    <group>
                        <field name="new_pin" password="True" required="1" placeholder="4-digit PIN" />
                    </group>
                    <footer>
                        <button name="action_change_pin" string="Change PIN" type="object" class="btn-primary" />
                        <button string="Cancel" class="btn-secondary" special="cancel" />
                    </footer>
                </form>
            </field>
        </record>

        
        <record id="action_havano_change_pin_wizard" model="ir.actions.act_window">
            <field name="name">Change My PIN</field>
            <field name="res_model">havano.change.pin.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>


        
        <record id="view_my_cashiers_tree" model="ir.ui.view">
            <field name="name">res.users.my.cashiers.list</field>
            <field name="model">res.users</field>
            <field name="arch" type="xml">
                <list string="Users" default_order="create_date desc">
                    <field name="name" />
                    <field name="login" string="Email / Username" />
                    <field name="phone" />
                    <field name="pin" />
                    <field name="havano_role" string="User Role" />
                    <field name="allow_backoffice" string="Backoffice" widget="boolean_toggle" optional="show" />
                    <field name="active" widget="boolean_toggle" optional="show" />
                </list>
            </field>
        </record>

        
        <record id="view_my_cashiers_form" model="ir.ui.view">
            <field name="name">res.users.my.cashiers.form</field>
            <field name="model">res.users</field>
            <field name="arch" type="xml">
                <form string="Employee">
                    <sheet>
                        <widget name="web_ribbon" title="Archived" bg_color="text-danger" invisible="active" />
                        <div class="oe_title mb-4">
                            <h1>
                                <field name="name" required="1" />
                            </h1>
                        </div>
                        <group>
                            <group>
                                <!-- LEFT COLUMN -->
                                <field name="havano_role" string="User Role" />
                                <field name="pin" string="POS Login PIN" widget="pos_pin_boxes" />
                                <field name="login" string="Backoffice email (optional)" required="0" />
                                <field name="phone" string="Phone number" />
                                <field name="has_password" invisible="1" />
                                
                                <label for="allow_backoffice" string="Access Backoffice" />
                                <div class="o_row">
                                    <field name="allow_backoffice" widget="boolean_toggle" />
                                    <button name="%(action_havano_change_password_wizard)d" string="Set Backoffice Password" type="action" class="btn btn-primary btn-sm ms-3" context="{'default_user_id': id}" invisible="not allow_backoffice or has_password" />
                                    <button name="%(action_havano_change_password_wizard)d" string="Change Backoffice Password" type="action" class="btn btn-secondary btn-sm ms-3" context="{'default_user_id': id}" invisible="not allow_backoffice or not has_password" />
                                </div>
                                
                                <field name="active" string="Active User" widget="boolean_toggle" />
                            </group>
                            <group>
                                <!-- RIGHT COLUMN -->
                                <field name="default_store_id" string="Default Store" options="{'no_create': True}" />
                                <field name="store_ids" string="Allowed Stores" widget="many2many_tags" options="{'no_create': True}" />
                                <field name="allow_discount" string="Discount Enable" widget="boolean_toggle" />
                                <field name="max_discount_percent" invisible="allow_discount == False" />
                                <field name="require_shift" string="Require Shift" widget="boolean_toggle" />
                                <field name="tenant_id" invisible="1" />
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        
        <record id="action_my_cashiers" model="ir.actions.act_window">
            <field name="name">Users</field>
            <field name="res_model">res.users</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[]</field>
            <field name="context">{'default_havano_role': 'user'}</field>
            <field name="view_ids" eval="[(5, 0, 0),                 (0, 0, {'view_mode': 'list', 'view_id': ref('view_my_cashiers_tree')}),                 (0, 0, {'view_mode': 'form', 'view_id': ref('view_my_cashiers_form')})]" />
        </record>
        <!-- Users & Roles Parent Menu -->
        <menuitem id="menu_my_users_and_roles" name="Users &amp; Roles" parent="menu_my_business_root" sequence="30" />

        <menuitem id="menu_my_cashiers" name="Users" parent="menu_my_users_and_roles" action="action_my_cashiers" sequence="10" />

        <menuitem id="menu_my_user_rights_profiles" name="User Rights Profiles" parent="menu_my_users_and_roles" action="action_user_rights_profiles" sequence="20" />

        
        <record id="action_my_subscription" model="ir.actions.server">
            <field name="name">My Subscription</field>
            <field name="model_id" ref="model_havanoposdesk_tenant" />
            <field name="state">code</field>
            <field name="code">
tenant_id = env.user.tenant_id
if not tenant_id:
    # Fallback to the first available tenant (useful for System Admin)
    tenant_id = env['havanoposdesk.tenant'].search([], limit=1)

if tenant_id:
    action = {
        'type': 'ir.actions.act_window',
        'name': 'My Subscription',
        'res_model': 'havanoposdesk.tenant',
        'res_id': tenant_id.id,
        'view_mode': 'form',
        'target': 'current',
    }
else:
    action = {
        'type': 'ir.actions.client',
        'tag': 'display_notification',
        'params': {
            'title': 'No Subscription',
            'message': 'You do not belong to any tenant subscription.',
            'type': 'danger',
            'sticky': False,
        }
    }
            </field>
        </record>
        <menuitem id="menu_my_subscription" name="My Subscription" parent="menu_my_business_root" action="action_my_subscription" sequence="40" />
        
        <menuitem id="menu_my_business_settings_parent" name="Currencies" parent="menu_my_business_root" sequence="100" />
        
        
        <menuitem id="menu_my_business_currency" name="Currencies" parent="menu_accounts_master" action="base.action_currency_form" sequence="20" />

        
        <record id="view_havanoposdesk_currency_rate_tree" model="ir.ui.view">
            <field name="name">havanoposdesk.currency.rate.list</field>
            <field name="model">res.currency.rate</field>
            <field name="arch" type="xml">
                <list string="Exchange Rates" editable="bottom">
                    <field name="currency_id" />
                    <field name="name" string="Date" />
                    <field name="company_rate" string="Unit per Base Currency" digits="[12,6]" />
                    <field name="inverse_company_rate" string="Base Currency per Unit" digits="[12,6]" optional="show" />
                </list>
            </field>
        </record>

        
        <record id="action_havanoposdesk_exchange_rates" model="ir.actions.act_window">
            <field name="name">Exchange Rates</field>
            <field name="res_model">res.currency.rate</field>
            <field name="view_mode">list,form</field>
            <field name="view_ids" eval="[(5, 0, 0),                 (0, 0, {'view_mode': 'list', 'view_id': ref('view_havanoposdesk_currency_rate_tree')})]" />
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new Exchange Rate
                </p>
            </field>
        </record>
        
        <menuitem id="menu_my_business_exchange_rate" name="Exchange Rates" parent="menu_accounts_master" action="action_havanoposdesk_exchange_rates" sequence="30" />

        
        <menuitem id="menu_my_business_analytics" name="Analytics" parent="menu_my_business_root" sequence="40" />
    </data>
</odoo>