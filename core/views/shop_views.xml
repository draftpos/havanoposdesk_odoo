<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Shop List (Tree) View -->
        <record id="view_havanoposdesk_shop_tree" model="ir.ui.view">
            <field name="name">havanoposdesk.shop.tree</field>
            <field name="model">havanoposdesk.shop</field>
            <field name="arch" type="xml">
                <list string="Shops">
                    <field name="name"/>
                    <field name="tenant_id"/>
                    <field name="active" optional="show"/>
                </list>
            </field>
        </record>

        <!-- Shop Form View -->
        <record id="view_havanoposdesk_shop_form" model="ir.ui.view">
            <field name="name">havanoposdesk.shop.form</field>
            <field name="model">havanoposdesk.shop</field>
            <field name="arch" type="xml">
                <form string="Shop">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="tenant_id" options="{'no_create': True}"/>
                            </group>
                            <group>
                                <field name="active"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Shop Action -->
        <record id="action_havanoposdesk_shop" model="ir.actions.act_window">
            <field name="name">Shops</field>
            <field name="res_model">havanoposdesk.shop</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
