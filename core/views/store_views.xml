<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Store List (Tree) View -->
        <record id="view_havanoposdesk_store_tree" model="ir.ui.view">
            <field name="name">havanoposdesk.store.tree</field>
            <field name="model">havanoposdesk.store</field>
            <field name="arch" type="xml">
                <list string="Stores">
                    <field name="name"/>
                    <field name="tenant_id" invisible="context.get('tenant_id')"/>
                    <field name="terminal_count"/>
                    <field name="last_open"/>
                    <field name="sales_count"/>
                    <field name="purchases_count"/>
                    <field name="sale_value"/>
                    <field name="users_count"/>
                    <field name="active" optional="show"/>
                </list>
            </field>
        </record>

        <!-- Store Form View -->
        <record id="view_havanoposdesk_store_form" model="ir.ui.view">
            <field name="name">havanoposdesk.store.form</field>
            <field name="model">havanoposdesk.store</field>
            <field name="arch" type="xml">
                <form string="Store">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="tenant_id" options="{'no_create': True}"/>
                            </group>
                            <group>
                                <field name="active"/>
                                <field name="is_default"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Store Action -->
        <record id="action_havanoposdesk_store" model="ir.actions.act_window">
            <field name="name">Stores</field>
            <field name="res_model">havanoposdesk.store</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
