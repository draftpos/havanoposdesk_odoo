<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Restrict standard app menus to system admins only -->
        <record id="mail.menu_root_discuss" model="ir.ui.menu">
            <field name="group_ids" eval="[(6, 0, [ref('base.group_system')])]"/>
        </record>
        <record id="spreadsheet_dashboard.spreadsheet_dashboard_menu_root" model="ir.ui.menu">
            <field name="group_ids" eval="[(6, 0, [ref('base.group_system')])]"/>
        </record>
        <record id="utm.menu_link_tracker_root" model="ir.ui.menu">
            <field name="group_ids" eval="[(6, 0, [ref('base.group_system')])]"/>
        </record>

        <!-- Apps menu: system admin only -->
        <record id="base.menu_management" model="ir.ui.menu">
            <field name="group_ids" eval="[(6, 0, [ref('base.group_system')])]"/>
        </record>

        <!--
            Settings icon: grant access to Tenant Admins directly.
            group_erp_manager is the native Odoo "Settings" group.
            We override group_ids so that ANY of: system, erp_manager, or
            group_tenant_admin can see the icon — this is a runtime check,
            no migration needed.
        -->
        <record id="base.menu_administration" model="ir.ui.menu">
            <field name="group_ids" eval="[(6, 0, [ref('base.group_system'), ref('base.group_erp_manager'), ref('havanoposdesk_odoo.group_tenant_admin')])]"/>
        </record>

        <!-- Hide "General Settings" tab inside Settings: system admin only -->
        <record id="base.menu_config" model="ir.ui.menu">
            <field name="active" eval="True"/>
            <field name="group_ids" eval="[(6, 0, [ref('base.group_system')])]"/>
        </record>

        <!-- Hide Translations: system admin only -->
        <record id="base.menu_translation" model="ir.ui.menu">
            <field name="active" eval="True"/>
            <field name="group_ids" eval="[(6, 0, [ref('base.group_system')])]"/>
        </record>

        <!-- Hide Technical: system admin only -->
        <record id="base.menu_custom" model="ir.ui.menu">
            <field name="active" eval="True"/>
            <field name="group_ids" eval="[(6, 0, [ref('base.group_system')])]"/>
        </record>

        <!-- Hide Users &amp; Companies: system admin only -->
        <record id="base.menu_users" model="ir.ui.menu">
            <field name="active" eval="True"/>
            <field name="group_ids" eval="[(6, 0, [ref('base.group_system')])]"/>
        </record>
    </data>
</odoo>
