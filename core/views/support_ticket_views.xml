<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="view_support_ticket_tree" model="ir.ui.view">
        <field name="name">havanoposdesk.support.ticket.tree</field>
        <field name="model">havanoposdesk.support.ticket</field>
        <field name="arch" type="xml">
            <list string="Support Tickets" decoration-info="status == 'new'" decoration-warning="status == 'in_progress'" decoration-success="status == 'resolved'">
                <field name="name" />
                <field name="email" />
                <field name="phone" />
                <field name="tenant_id" />
                <field name="user_id" />
                <field name="status" widget="badge" />
                <field name="create_date" string="Created On" optional="show" />
            </list>
        </field>
    </record>

    <record id="view_support_ticket_form" model="ir.ui.view">
        <field name="name">havanoposdesk.support.ticket.form</field>
        <field name="model">havanoposdesk.support.ticket</field>
        <field name="arch" type="xml">
            <form string="Support Ticket">
                <header>
                    <field name="status" widget="statusbar" statusbar_visible="new,in_progress,resolved" options="{'clickable': '1'}" />
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Subject" />
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="email" />
                            <field name="phone" />
                        </group>
                        <group>
                            <field name="tenant_id" />
                            <field name="user_id" />
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description" placeholder="Message content..." />
                        </page>
                    </notebook>
                </sheet>
                <chatter />
            </form>
        </field>
    </record>

    <record id="action_support_ticket" model="ir.actions.act_window">
        <field name="name">Support Tickets</field>
        <field name="res_model">havanoposdesk.support.ticket</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No support tickets found!
            </p>
        </field>
    </record>

    
    <menuitem id="menu_saas_support_tickets" name="Support Tickets" parent="menu_saas_root" action="action_support_ticket" sequence="60" />
</odoo>