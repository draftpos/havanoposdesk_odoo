<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_havanoposdesk_tenant_tree" model="ir.ui.view">
            <field name="name">havanoposdesk.tenant.tree</field>
            <field name="model">havanoposdesk.tenant</field>
            <field name="arch" type="xml">
                <list string="Tenants">
                    <field name="name"/>
                    <field name="subscription_plan_id"/>
                    <field name="subscription_state"
                           widget="badge"
                           decoration-success="subscription_state == 'active'"
                           decoration-warning="subscription_state == 'expired'"
                           decoration-danger="subscription_state == 'cancelled'"/>
                    <field name="active" optional="show"/>
                </list>
            </field>
        </record>

        <record id="view_havanoposdesk_tenant_form" model="ir.ui.view">
            <field name="name">havanoposdesk.tenant.form</field>
            <field name="model">havanoposdesk.tenant</field>
            <field name="arch" type="xml">
                <form string="Tenant">
                    <header>
                        <button name="action_approve"
                                type="object"
                                string="Approve / Activate"
                                class="oe_highlight"
                                invisible="subscription_state == 'active'"
                                groups="base.group_system"/>

                        <button name="action_expire"
                                type="object"
                                string="Set Expired"
                                invisible="subscription_state == 'expired'"
                                groups="base.group_system"/>

                        <button name="action_cancel"
                                type="object"
                                string="Cancel Subscription"
                                class="btn-danger"
                                invisible="subscription_state == 'cancelled'"
                                groups="base.group_system"/>

                        <button name="action_pay_and_activate"
                                type="object"
                                string="Pay &amp; Activate Plan"
                                class="btn-success"
                                invisible="subscription_state == 'active' or not subscription_plan_id"/>

                        <button name="action_upgrade_plan"
                                type="object"
                                string="Change/Upgrade Plan"
                                class="oe_highlight"
                                invisible="subscription_state == 'pending'"/>

                        <field name="subscription_state"
                               widget="statusbar"
                               statusbar_visible="active,pending,expired,cancelled"/>
                    </header>

                    <sheet>
                        <group>
                            <group string="Subscription Details">
                                <field name="name"
                                       readonly="not context.get('is_super_admin', False)"/>
                                <field name="subscription_plan_id"
                                       options="{'no_create': True}"
                                       readonly="1"/>
                                <field name="payment_status" readonly="1"/>
                            </group>

                            <group string="Duration &amp; Status">
                                <field name="subscription_start_date" readonly="1"/>
                                <field name="subscription_end_date" readonly="1"/>
                                <field name="active"
                                       readonly="not context.get('is_super_admin', False)"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Tenant Upgrade Wizard View -->
        <record id="view_tenant_upgrade_wizard_form" model="ir.ui.view">
            <field name="name">havanoposdesk.tenant.upgrade.wizard.form</field>
            <field name="model">havanoposdesk.tenant.upgrade.wizard</field>
            <field name="arch" type="xml">
                <form string="Change / Upgrade Plan">
                    <group>
                        <field name="subscription_plan_id"
                               options="{'no_create': True}"/>
                    </group>
                    <footer>
                        <button string="Confirm Upgrade"
                                name="action_confirm"
                                type="object"
                                class="btn-primary"/>
                        <button string="Cancel"
                                class="btn-secondary"
                                special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

    </data>
</odoo>