<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Havano White-label: Override Odoo templates with Havano branding.
    -->

    <!-- 1. Override web.layout to change the page title from "Odoo" to "Havano" -->
    <template id="havano_layout_title" inherit_id="web.layout" name="Havano Layout Title">
        <xpath expr="//title" position="replace">
            <title t-esc="title or 'Havano'"/>
        </xpath>
    </template>

    <!-- 2. Override web.layout to change the favicon -->
    <template id="havano_layout_favicon" inherit_id="web.layout" name="Havano Layout Favicon">
        <xpath expr="//link[@rel='shortcut icon']" position="replace">
            <t t-set="havano_favicon" t-value="request.env['ir.config_parameter'].sudo().get_param('havanoposdesk.favicon', '/havanoposdesk_odoo/static/src/img/favicon.png')"/>
            <link type="image/png" rel="shortcut icon" t-att-href="havano_favicon"/>
        </xpath>
    </template>

    <!-- 3. Override web.login_layout to remove "Powered by Odoo" footer link and add a loader -->
    <template id="havano_login_footer" inherit_id="web.login_layout" name="Havano Login Footer">
        <!-- Replace "Powered by Odoo" with "Powered by Havano" -->
        <xpath expr="//a[contains(@href,'odoo.com')]" position="replace">
            <a href="https://havano.cloud" target="_blank">Powered by <span>Havano</span></a>
        </xpath>

        <!-- Inject a full-screen premium loader overlay before the main container -->
        <xpath expr="//div[contains(@class, 'container')]" position="before">
            <div id="havano-login-loader" style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: radial-gradient(circle at center, #120e2e 0%, #080616 100%); display: flex; flex-direction: column; justify-content: center; align-items: center; z-index: 999999; transition: opacity 0.6s cubic-bezier(0.4, 0, 0.2, 1), visibility 0.6s; opacity: 1; visibility: visible;">
                <div class="havano-loader-content" style="text-align: center; display: flex; flex-direction: column; align-items: center; justify-content: center;">
                    <!-- Pulser container for Logo -->
                    <div style="margin-bottom: 2rem; position: relative;">
                        <!-- Glowing background effect -->
                        <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 140px; height: 60px; background: radial-gradient(circle, rgba(124, 77, 255, 0.2) 0%, rgba(0, 188, 212, 0) 70%); filter: blur(10px); animation: pulse-glow 2s infinite ease-in-out;"></div>
                        <img src="/havanoposdesk_odoo/static/src/img/havano_logo.svg" alt="Havano" style="height: 48px; width: auto; position: relative; z-index: 1; animation: pulse-logo 2s infinite ease-in-out;" onerror="this.style.display='none'; document.getElementById('havano-loader-fallback').style.display='block';"/>
                        <div id="havano-loader-fallback" style="display: none; font-size: 28px; font-weight: 800; color: #FFFFFF; font-family: 'Outfit', 'Inter', sans-serif; letter-spacing: -0.5px; position: relative; z-index: 1;">Havano</div>
                    </div>
                    
                    <!-- Modern loading track -->
                    <div style="width: 160px; height: 4px; background: rgba(255, 255, 255, 0.08); border-radius: 999px; overflow: hidden; margin-bottom: 1.5rem; position: relative;">
                        <div style="height: 100%; width: 50%; background: linear-gradient(90deg, #7C4DFF 0%, #00BCD4 100%); border-radius: 999px; position: absolute; left: -50%; animation: loading-bar 1.8s infinite cubic-bezier(0.4, 0, 0.2, 1); box-shadow: 0 0 8px rgba(0, 188, 212, 0.5);"></div>
                    </div>
                    
                    <span style="color: rgba(255, 255, 255, 0.6); font-family: 'Inter', system-ui, -apple-system, sans-serif; font-size: 13px; font-weight: 500; letter-spacing: 0.05em; text-transform: uppercase; animation: pulse-text 1.8s infinite ease-in-out;">Loading Havano...</span>
                </div>
            </div>
            
            <style>
                @keyframes pulse-logo {
                    0%, 100% { transform: scale(0.97); opacity: 0.9; }
                    50% { transform: scale(1.03); opacity: 1; }
                }
                @keyframes pulse-glow {
                    0%, 100% { transform: translate(-50%, -50%) scale(0.85); opacity: 0.6; }
                    50% { transform: translate(-50%, -50%) scale(1.15); opacity: 1; }
                }
                @keyframes pulse-text {
                    0%, 100% { opacity: 0.5; }
                    50% { opacity: 0.85; }
                }
                @keyframes loading-bar {
                    0% { left: -50%; width: 30%; }
                    50% { width: 40%; }
                    100% { left: 110%; width: 30%; }
                }
            </style>
            
            <script>
                (function() {
                    function removeLoader() {
                        var loader = document.getElementById('havano-login-loader');
                        if (loader) {
                            loader.style.opacity = '0';
                            loader.style.visibility = 'hidden';
                            setTimeout(function() {
                                if (loader.parentNode) {
                                    loader.parentNode.removeChild(loader);
                                }
                            }, 600);
                        }
                    }

                    if (document.readyState === 'complete') {
                        removeLoader();
                    } else {
                        window.addEventListener('load', removeLoader);
                        // Fallback in case window load event fails/hangs due to external assets
                        setTimeout(removeLoader, 8000);
                    }
                })();
            </script>
        </xpath>
    </template>

    <!-- 4. Override web.login to bypass OWL user switch component and render the form instantly -->
    <template id="havano_custom_login" inherit_id="web.login" name="Havano Custom Login">
        <xpath expr="." position="replace">
            <t t-call="web.login_layout">
                <div class="oe_structure" id="oe_structure_login_top"/>
                
                <form class="oe_login_form" role="form" t-attf-action="/web/login" method="post" onsubmit="this.action = '/web/login' + location.hash">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                    <!-- Database selector if multiple databases exist -->
                    <div class="mb-3" t-if="databases and len(databases) &gt; 1">
                        <label for="db" class="col-form-label">Database</label>
                        <div class="input-group">
                            <input type="text" name="db" t-att-value="request.db" id="db" class="form-control" required="required" readonly="readonly"/>
                            <a role="button" href="/web/database/selector" class="btn border border-start-0">Select <i class="fa fa-database" role="img" aria-label="Database" title="Database"></i></a>
                        </div>
                    </div>

                    <!-- Email / Login -->
                    <div class="mb-3 field-login">
                        <label for="login" class="form-label d-flex justify-content-between">Email</label>
                        <input type="text" placeholder="Enter your email" name="login" t-att-value="login" id="login" class="form-control" required="required" autocapitalize="off" autocomplete="username" autofocus="autofocus"/>
                    </div>

                    <!-- Password -->
                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-start">
                            <label for="password" class="form-label">Password</label>
                        </div>
                        <div class="input-group mb-1">
                            <input type="password" placeholder="Enter your password" name="password" id="password" class="form-control" required="required" autocomplete="current-password" maxlength="4096"/>
                            <button type="button" class="btn btn-sm border border-start-0 o_show_password" id="havano_show_password_btn">
                                <i class="fa fa-eye" id="havano_password_eye_icon"/>
                            </button>
                        </div>
                        <!-- Caps Lock Warning -->
                        <div id="havano_caps_lock_warning" class="text-warning small mt-1" style="display: none;">
                            <i class="fa fa-exclamation-triangle"/> Caps Lock is on
                        </div>
                    </div>

                    <!-- Errors / Messages -->
                    <p class="alert alert-danger" t-if="error" role="alert">
                        <t t-esc="error"/>
                    </p>
                    <p class="alert alert-success" t-if="message" role="status">
                        <t t-esc="message"/>
                    </p>

                    <!-- Login buttons -->
                    <div class="oe_login_buttons text-center d-grid mb-1 pt-3">
                        <button type="submit" class="btn btn-primary">Log in</button>
                        <t t-if="debug">
                            <button type="submit" name="redirect" value="/web/become" class="btn btn-link btn-sm">Log in as superuser</button>
                        </t>
                        <t t-call="web.login_oauth"/>
                    </div>

                    <input type="hidden" name="type" value="password"/>
                    <input type="hidden" name="redirect" t-att-value="redirect"/>
                </form>
                
                <div class="oe_structure" id="oe_structure_login_bottom"/>

                <!-- Vanilla JS to make interactions fast and dynamic without Odoo JS dependencies -->
                <script>
                    (function() {
                        // Toggle password visibility
                        var toggleBtn = document.getElementById('havano_show_password_btn');
                        var passwordInput = document.getElementById('password');
                        var eyeIcon = document.getElementById('havano_password_eye_icon');
                        if (toggleBtn &amp;&amp; passwordInput &amp;&amp; eyeIcon) {
                            toggleBtn.addEventListener('click', function(e) {
                                e.preventDefault();
                                if (passwordInput.type === 'password') {
                                    passwordInput.type = 'text';
                                    eyeIcon.classList.remove('fa-eye');
                                    eyeIcon.classList.add('fa-eye-slash');
                                } else {
                                    passwordInput.type = 'password';
                                    eyeIcon.classList.remove('fa-eye-slash');
                                    eyeIcon.classList.add('fa-eye');
                                }
                            });
                        }

                        // Caps Lock warning indicator
                        var capsWarning = document.getElementById('havano_caps_lock_warning');
                        if (passwordInput &amp;&amp; capsWarning) {
                            passwordInput.addEventListener('keydown', function(e) {
                                if (e.getModifierState &amp;&amp; e.getModifierState('CapsLock')) {
                                    capsWarning.style.display = 'block';
                                } else {
                                    capsWarning.style.display = 'none';
                                }
                            });
                            passwordInput.addEventListener('keyup', function(e) {
                                if (e.getModifierState &amp;&amp; !e.getModifierState('CapsLock')) {
                                    capsWarning.style.display = 'none';
                                }
                            });
                        }
                    })();
                </script>
            </t>
        </xpath>
    </template>


    <!-- 4. Override webclient_offline to remove Odoo branding -->
    <template id="havano_offline_page" name="Havano Offline Page">
        <t t-call="web.layout">
            <t t-set="head">
                <style>
                    body {
                        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
                        display: flex;
                        flex-direction: column;
                        align-items: center;
                        justify-content: center;
                        height: 100vh;
                        background-color: #f8f9fa;
                        color: #333;
                    }
                    .offline-container {
                        text-align: center;
                        padding: 2rem;
                        background: white;
                        border-radius: 8px;
                        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
                    }
                    h1 { color: #714B67; }
                </style>
            </t>
            <t t-set="title">Offline</t>
            <div class="offline-container">
                <h1>You are offline</h1>
                <p>Check your internet connection and try again.</p>
                <p><strong><t t-esc="app_name"/></strong></p>
                <button onclick="location.reload()" style="padding: 10px 20px; background-color: #714B67; color: white; border: none; border-radius: 4px; cursor: pointer;">
                    Retry
                </button>
            </div>
        </t>
    </template>

</odoo>
