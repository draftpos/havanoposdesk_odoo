<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.havanoposdesk</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="50"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <!-- Hide native General Settings tab -->
            <xpath expr="//app[@name='general_settings']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//form" position="inside">
                <field name="is_super_user" invisible="1"/>
                <!-- SaaS Config Settings -->
                <app logo="/havanoposdesk_odoo/static/description/saas_config.png" data-string="SaaS Config" string="SaaS Config" name="havanoposdesk_saas" groups="base.group_system">
                    <block title="SaaS Administration" name="saas_config">
                        <div>
                            <p class="text-muted">Global SaaS settings, users, and tenants configuration.</p>
                        </div>
                    </block>
                    <block title="White-labeling" name="whitelabel_config">
                        <div class="row mt8 o_settings_container">
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_right_pane">
                                    <label for="havano_app_name" string="App Name"/>
                                    <div class="text-muted">Name shown in the browser tab, PWA install prompt, and login page</div>
                                    <div class="content-group mt8">
                                        <field name="havano_app_name" class="o_light_label" placeholder="Havano"/>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_right_pane">
                                    <label for="havano_web_base_url" string="Web Base URL Path"/>
                                    <div class="text-muted">Custom URL path (e.g. &quot;havano&quot; → /havano). Restart required after change.</div>
                                    <div class="content-group mt8">
                                        <field name="havano_web_base_url" class="o_light_label" placeholder="havano"/>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_right_pane">
                                    <label for="havano_bot_name" string="Bot Name"/>
                                    <div class="text-muted">The name of the chat assistant visible in the Discuss sidebar</div>
                                    <div class="content-group mt8">
                                        <field name="havano_bot_name" class="o_light_label" placeholder="HavanoBot"/>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_right_pane">
                                    <label for="havano_bot_email" string="Bot Email"/>
                                    <div class="content-group mt8">
                                        <field name="havano_bot_email" class="o_light_label" placeholder="bot@havano.cloud"/>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_right_pane">
                                    <label for="havano_vendor_domain" string="Vendor Domain"/>
                                    <div class="text-muted">Shown in the login footer (e.g. havano.cloud)</div>
                                    <div class="content-group mt8">
                                        <field name="havano_vendor_domain" class="o_light_label" placeholder="havano.cloud"/>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_right_pane">
                                    <label for="havano_vendor_url" string="Vendor URL"/>
                                    <div class="text-muted">Full URL for the vendor website link in the login footer</div>
                                    <div class="content-group mt8">
                                        <field name="havano_vendor_url" class="o_light_label" placeholder="https://havano.cloud"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row mt8 o_settings_container">
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_right_pane">
                                    <label for="havano_favicon" string="X Icon"/>
                                    <div class="content-group mt8">
                                        <field name="havano_favicon" class="o_light_label" placeholder="/havanoposdesk_odoo/static/src/img/favicon.png"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row mt8 o_settings_container">
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_right_pane">
                                    <label for="havano_support_phone" string="Support Phone"/>
                                    <div class="content-group mt8">
                                        <field name="havano_support_phone" class="o_light_label"/>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_right_pane">
                                    <label for="havano_sales_phone" string="Sales Phone"/>
                                    <div class="content-group mt8">
                                        <field name="havano_sales_phone" class="o_light_label"/>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_right_pane">
                                    <label for="havano_whatsapp_phone" string="WhatsApp Phone"/>
                                    <div class="content-group mt8">
                                        <field name="havano_whatsapp_phone" class="o_light_label"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </block>
                    <block title="User Verification &amp; Suspension" name="saas_verification">
                        <setting id="verification_grace_period_setting" help="Specify the grace period for self-registered users to verify their email before their account gets suspended.">
                            <div class="content-group">
                                <div class="d-flex align-items-center gap-2">
                                    <span>Grace Period:</span>
                                    <field name="havano_verification_grace_number" class="oe_inline" style="width: 80px;"/>
                                    <field name="havano_verification_grace_unit" class="oe_inline" style="width: 100px;"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                    <block title="Bugsink Error Logging Integration" name="bugsink_config">
                        <div class="row mt8 o_settings_container">
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_right_pane">
                                    <label for="havano_bugsink_base_url" string="Bugsink Base URL"/>
                                    <div class="text-muted">E.g., https://bugsink.example.com</div>
                                    <div class="content-group mt8">
                                        <field name="havano_bugsink_base_url" class="o_light_label" placeholder="https://..."/>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_right_pane">
                                    <label for="havano_bugsink_project_id" string="Project ID"/>
                                    <div class="text-muted">The numeric Bugsink Project ID</div>
                                    <div class="content-group mt8">
                                        <field name="havano_bugsink_project_id" class="o_light_label"/>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_right_pane">
                                    <label for="havano_bugsink_api_token" string="API Token"/>
                                    <div class="text-muted">Bearer token for Bugsink API</div>
                                    <div class="content-group mt8">
                                        <field name="havano_bugsink_api_token" class="o_light_label" password="True"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </block>
                </app>
                
                <!-- My Business Settings -->
                <app logo="/havanoposdesk_odoo/static/description/mybusiness.png" data-string="My Business" string="My Business" name="havanoposdesk_my_business" groups="base.group_user">
                    <field name="tenant_id" invisible="1"/>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="biz_allow_multi_currency"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="biz_allow_multi_currency" string="Multi-Currencies"/>
                                <div class="text-muted">
                                    Allow multiple currencies for your business
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_right_pane">
                                <label for="biz_currency_id"/>
                                <div class="text-muted">
                                    Main currency of your business
                                </div>
                                <div class="content-group">
                                    <div class="mt16">
                                        <field name="biz_currency_id" class="o_light_label"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <block title="Mobile POS Configuration" name="mobile_pos_config">
                        <div class="row mt16 o_settings_container">
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                    <field name="biz_enable_quotations"/>
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="biz_enable_quotations" string="Enable Quotations"/>
                                    <div class="text-muted">Allow quotations management in POS app</div>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                    <field name="biz_enable_uom_conversion"/>
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="biz_enable_uom_conversion" string="Enable UOM Conversion"/>
                                    <div class="text-muted">Allow multi-UOM packaging conversions in POS</div>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                    <field name="biz_enable_payment_entries"/>
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="biz_enable_payment_entries" string="Enable Payment Entries"/>
                                    <div class="text-muted">Display Payment Entries management in POS app</div>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                    <field name="biz_show_qty_on_hand"/>
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="biz_show_qty_on_hand" string="Show Stock Quantity on Hand"/>
                                    <div class="text-muted">Show stock quantity indicator on POS product cards</div>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                    <field name="biz_enable_shift"/>
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="biz_enable_shift" string="Enable Shift Management"/>
                                    <div class="text-muted">Track sales shifts and cash drawer opening/closing</div>
                                </div>
                            </div>
                        </div>
                    </block>
                </app>
                
                <!-- Sales Settings -->
                <app logo="/havanoposdesk_odoo/static/description/sales.png" data-string="Sales" string="Sales" name="havanoposdesk_sales" groups="base.group_user">
                    <block title="Sales Configuration" name="sales_config">
                        <div>
                            <div class="row mt16 o_settings_container">
                                <div class="col-12 col-lg-6 o_setting_box">
                                    <div class="o_setting_left_pane">
                                        <field name="biz_allow_credit_sales"/>
                                    </div>
                                    <div class="o_setting_right_pane">
                                        <label for="biz_allow_credit_sales"/>
                                        <div class="text-muted">
                                            Allow creating sales invoices on credit (e.g. from POS terminals or API).
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </block>
                    <block title="Sequence Configuration" name="sales_seq_config">
                        <setting id="sale_seq_setting" string="Sales Orders">
                            <div class="content-group">
                                <div class="d-flex align-items-center gap-2">
                                    <span>Prefix:</span>
                                    <field name="biz_sale_seq_prefix" style="width: 100px;" class="oe_inline"/>
                                    <span>Next:</span>
                                    <field name="biz_sale_seq_next" style="width: 100px;" class="oe_inline"/>
                                    <span>Padding:</span>
                                    <field name="biz_sale_seq_padding" style="width: 80px;" class="oe_inline"/>
                                </div>
                            </div>
                        </setting>
                        <setting id="sale_ret_seq_setting" string="Credit Notes (Returns)">
                            <div class="content-group">
                                <div class="d-flex align-items-center gap-2">
                                    <span>Prefix:</span>
                                    <field name="biz_sale_ret_seq_prefix" style="width: 100px;" class="oe_inline"/>
                                    <span>Next:</span>
                                    <field name="biz_sale_ret_seq_next" style="width: 100px;" class="oe_inline"/>
                                    <span>Padding:</span>
                                    <field name="biz_sale_ret_seq_padding" style="width: 80px;" class="oe_inline"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                </app>
                
                <!-- Stock Settings -->
                <app logo="/havanoposdesk_odoo/static/description/stock.png" data-string="Stock" string="Stock" name="havanoposdesk_stock" groups="base.group_user">
                    <block title="Inventory Operations" name="stock_config">
                        <setting id="allow_negative_stock_setting" help="Allow selling products even when their quantity on hand is zero or less. Purchasing more will compensate the negative balance automatically.">
                            <field name="biz_allow_negative_stock"/>
                        </setting>
                        <setting id="allow_advanced_pricing_setting" help="Allow setting different prices based on pricelists (e.g. Retail, Wholesale) and multiple units of measure.">
                            <field name="biz_allow_advanced_pricing"/>
                        </setting>
                    </block>
                    <block title="Sequence Configuration" name="stock_seq_config">
                        <setting id="prod_seq_setting" string="Product Product Codes">
                            <div class="content-group">
                                <div class="d-flex align-items-center gap-2">
                                    <span>Prefix:</span>
                                    <field name="biz_prod_seq_prefix" style="width: 100px;" class="oe_inline"/>
                                    <span>Next:</span>
                                    <field name="biz_prod_seq_next" style="width: 100px;" class="oe_inline"/>
                                    <span>Padding:</span>
                                    <field name="biz_prod_seq_padding" style="width: 80px;" class="oe_inline"/>
                                </div>
                            </div>
                        </setting>
                        <setting id="stock_adj_seq_setting" string="Stock Adjustments">
                            <div class="content-group">
                                <div class="d-flex align-items-center gap-2">
                                    <span>Prefix:</span>
                                    <field name="biz_stock_adj_seq_prefix" style="width: 100px;" class="oe_inline"/>
                                    <span>Next:</span>
                                    <field name="biz_stock_adj_seq_next" style="width: 100px;" class="oe_inline"/>
                                    <span>Padding:</span>
                                    <field name="biz_stock_adj_seq_padding" style="width: 80px;" class="oe_inline"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                </app>

                <!-- Accounts Settings -->
                <app logo="/havanoposdesk_odoo/static/description/accounts.png" data-string="Accounts" string="Accounts" name="havanoposdesk_accounts" groups="base.group_user">
                    <block title="Accounting Configuration" name="accounts_config">
                        <div>
                            <p class="text-muted">Chart of accounts, taxes, and accounting settings will go here.</p>
                        </div>
                    </block>
                    <block title="Sequence Configuration" name="accounts_seq_config">
                        <setting id="pay_in_seq_setting" string="Payment Receipt (Receive Money)">
                            <div class="content-group">
                                <div class="d-flex align-items-center gap-2">
                                    <span>Prefix:</span>
                                    <field name="biz_pay_in_seq_prefix" style="width: 100px;" class="oe_inline"/>
                                    <span>Next:</span>
                                    <field name="biz_pay_in_seq_next" style="width: 100px;" class="oe_inline"/>
                                    <span>Padding:</span>
                                    <field name="biz_pay_in_seq_padding" style="width: 80px;" class="oe_inline"/>
                                </div>
                            </div>
                        </setting>
                        <setting id="pay_out_seq_setting" string="Payment Out (Send Money)">
                            <div class="content-group">
                                <div class="d-flex align-items-center gap-2">
                                    <span>Prefix:</span>
                                    <field name="biz_pay_out_seq_prefix" style="width: 100px;" class="oe_inline"/>
                                    <span>Next:</span>
                                    <field name="biz_pay_out_seq_next" style="width: 100px;" class="oe_inline"/>
                                    <span>Padding:</span>
                                    <field name="biz_pay_out_seq_padding" style="width: 80px;" class="oe_inline"/>
                                </div>
                            </div>
                        </setting>
                        <setting id="exp_seq_setting" string="Expenses">
                            <div class="content-group">
                                <div class="d-flex align-items-center gap-2">
                                    <span>Prefix:</span>
                                    <field name="biz_exp_seq_prefix" style="width: 100px;" class="oe_inline"/>
                                    <span>Next:</span>
                                    <field name="biz_exp_seq_next" style="width: 100px;" class="oe_inline"/>
                                    <span>Padding:</span>
                                    <field name="biz_exp_seq_padding" style="width: 80px;" class="oe_inline"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                </app>
                
                <!-- Suppliers Settings -->
                <app logo="/havanoposdesk_odoo/static/description/purchases.png" data-string="Suppliers" string="Suppliers" name="havanoposdesk_suppliers" groups="base.group_user">
                    <block title="Purchasing Configuration" name="suppliers_config">
                        <div>
                            <p class="text-muted">Supplier and purchasing settings will go here.</p>
                        </div>
                    </block>
                    <block title="Sequence Configuration" name="suppliers_seq_config">
                        <setting id="purch_seq_setting" string="Purchase Orders">
                            <div class="content-group">
                                <div class="d-flex align-items-center gap-2">
                                    <span>Prefix:</span>
                                    <field name="biz_purch_seq_prefix" style="width: 100px;" class="oe_inline"/>
                                    <span>Next:</span>
                                    <field name="biz_purch_seq_next" style="width: 100px;" class="oe_inline"/>
                                    <span>Padding:</span>
                                    <field name="biz_purch_seq_padding" style="width: 80px;" class="oe_inline"/>
                                </div>
                            </div>
                        </setting>
                        <setting id="purch_ret_seq_setting" string="Debit Notes (Returns)">
                            <div class="content-group">
                                <div class="d-flex align-items-center gap-2">
                                    <span>Prefix:</span>
                                    <field name="biz_purch_ret_seq_prefix" style="width: 100px;" class="oe_inline"/>
                                    <span>Next:</span>
                                    <field name="biz_purch_ret_seq_next" style="width: 100px;" class="oe_inline"/>
                                    <span>Padding:</span>
                                    <field name="biz_purch_ret_seq_padding" style="width: 80px;" class="oe_inline"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                </app>

            </xpath>
        </field>
    </record>
    
    <!-- Actions for each app to open the exact app settings -->
    <record id="action_havanoposdesk_settings_my_business" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="view_id" ref="res_config_settings_view_form"/>
        <field name="context">{'module': 'havanoposdesk_my_business'}</field>
    </record>

    <record id="action_havanoposdesk_settings_sales" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="view_id" ref="res_config_settings_view_form"/>
        <field name="context">{'module': 'havanoposdesk_sales'}</field>
    </record>

    <record id="action_havanoposdesk_settings_stock" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="view_id" ref="res_config_settings_view_form"/>
        <field name="context">{'module': 'havanoposdesk_stock'}</field>
    </record>

    <record id="action_havanoposdesk_settings_accounts" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="view_id" ref="res_config_settings_view_form"/>
        <field name="context">{'module': 'havanoposdesk_accounts'}</field>
    </record>

    <record id="action_havanoposdesk_settings_suppliers" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="view_id" ref="res_config_settings_view_form"/>
        <field name="context">{'module': 'havanoposdesk_suppliers'}</field>
    </record>
</odoo>

