<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>
        
        <record id="view_user_rights_profile_tree" model="ir.ui.view">
            <field name="name">havanoposdesk.user.rights.profile.list</field>
            <field name="model">havanoposdesk.user.rights.profile</field>
            <field name="arch" type="xml">
                <list string="User Rights Profiles">
                    <field name="name" />
                    <field name="is_additional_tax_enabled" />
                    <field name="food_tax" invisible="not is_additional_tax_enabled" />
                    <field name="tourism_tax" invisible="not is_additional_tax_enabled" />
                    <field name="tenant_id" groups="base.group_no_one" optional="show" />
                </list>
            </field>
        </record>

        
        <record id="view_user_rights_profile_form" model="ir.ui.view">
            <field name="name">havanoposdesk.user.rights.profile.form</field>
            <field name="model">havanoposdesk.user.rights.profile</field>
            <field name="arch" type="xml">
                <form string="User Rights Profile">
                    <sheet>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only" />
                            <h1>
                                <field name="name" placeholder="e.g. Cashier Profile, Supervisor Profile" required="1" />
                            </h1>
                        </div>
                        <group>
                            <group string="Tax Configuration">
                                <field name="is_additional_tax_enabled" />
                                <field name="food_tax" invisible="not is_additional_tax_enabled" required="is_additional_tax_enabled" />
                                <field name="tourism_tax" invisible="not is_additional_tax_enabled" required="is_additional_tax_enabled" />
                            </group>
                            <group string="Organization" groups="base.group_no_one">
                                <field name="tenant_id" options="{'no_create': True}" />
                            </group>
                        </group>
                        <notebook>
                            <page string="Permissions" name="permissions_page">
                                <field name="permission_ids">
                                    <list string="Permissions" editable="bottom" create="0" delete="0">
                                        <field name="feature" readonly="1" force_save="1" />
                                        <field name="can_read" widget="boolean_toggle" />
                                        <field name="can_create" widget="boolean_toggle" />
                                        <field name="can_update" widget="boolean_toggle" />
                                        <field name="can_delete" widget="boolean_toggle" />
                                        <field name="can_submit" widget="boolean_toggle" optional="show" />
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        
        <record id="action_user_rights_profiles" model="ir.actions.act_window">
            <field name="name">User Rights Profiles</field>
            <field name="res_model">havanoposdesk.user.rights.profile</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="view_user_rights_profile_tree" />
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new User Rights Profile
                </p>
                <p>
                    Configure profile permissions for Dashboard, POS, Quotations, Sales, Products, Stock, and more.
                </p>
            </field>
        </record>
    </data>
</odoo>