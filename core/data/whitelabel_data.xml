<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Seed default white-label system parameters (only on first install, not on upgrade) -->
        <function model="ir.config_parameter" name="set_param" eval="('web.web_app_name', 'Havano')"/>
        <function model="ir.config_parameter" name="set_param" eval="('havanoposdesk.theme_color', '#714B67')"/>
        <function model="ir.config_parameter" name="set_param" eval="('havanoposdesk.bot_name', 'HavanoBot')"/>
        <function model="ir.config_parameter" name="set_param" eval="('havanoposdesk.vendor_url', 'https://havano.cloud')"/>
        <function model="ir.config_parameter" name="set_param" eval="('havanoposdesk.vendor_domain', 'havano.cloud')"/>
        <function model="ir.config_parameter" name="set_param" eval="('havanoposdesk.web_base_url', 'havano')"/>
    </data>
</odoo>
