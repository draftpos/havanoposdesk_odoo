<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Product List (Tree) View -->
        <record id="view_havanoposdesk_product_tree" model="ir.ui.view">
            <field name="name">havanoposdesk.product.tree</field>
            <field name="model">havanoposdesk.product</field>
            <field name="arch" type="xml">
                <list  string="Products">
                    <field  name="name"/>
                    <field  name="item_code" optional="show"/>
                    <field  name="category_id" optional="show"/>
                    <field  name="uom_id" optional="show"/>
                    <field  name="buying_price" optional="show"/>
                    <field  name="selling_price" optional="show"/>
                    <field  name="track_qty" optional="show"/>
                    <field  name="opening_stock" string="On hand" optional="show"/>
                    <field  name="store_id" optional="show"/>
                    <field  name="color" column_invisible="1"/>
                    <field  name="tenant_id" column_invisible="1"/>
                </list>
            </field>
        </record>

        <!-- Product Form View -->
        <record id="view_havanoposdesk_product_form" model="ir.ui.view">
            <field name="name">havanoposdesk.product.form</field>
            <field name="model">havanoposdesk.product</field>
            <field name="arch" type="xml">
                <form string="Product">
                    <sheet>
                        <notebook>
                            <style>
                                /* Disable Odoo's forced ALL-CAPS on notebook tabs */
                                .o_notebook .nav-tabs .nav-link { text-transform: none !important; font-size: 14px; }
                            </style>
                            <page string="Details">
                                <group>
                                    <group string="Product information">
                                        <field name="name" class="border-bottom border-dark"/>
                                        <field name="category_id" options="{'no_create': True, 'no_create_edit': True}" class="border-bottom border-dark"/>
                                        <field name="uom_id" options="{'no_create': True, 'no_create_edit': True}" class="border-bottom border-dark"/>
                                        <field name="tenant_id" invisible="1"/>
                                        <field name="track_qty" class="border-bottom border-dark"/>
                                        <field name="store_id" class="border-bottom border-dark" options="{'no_create': True}"/>
                                        <field name="item_code" readonly="1" class="border-bottom border-dark"/>
                                        <field name="color" invisible="1"/>
                                    </group>
                                    <group string="Price information">
                                        <label for="buying_price"/>
                                        <div class="o_row">
                                            <field name="buying_price" class="border-bottom border-dark"/>
                                            <span class="text-muted ms-2" invisible="not purchase_tax_ids or not has_active_taxes">
                                                <field name="buy_price_with_tax" nolabel="1" class="oe_inline fw-bold"/> Including Tax
                                            </span>
                                        </div>
                                        
                                        <label for="selling_price"/>
                                        <div class="o_row">
                                            <field name="selling_price" class="border-bottom border-dark"/>
                                            <span class="text-muted ms-2" invisible="not sale_tax_ids or not has_active_taxes">
                                                <field name="sell_price_with_tax" nolabel="1" class="oe_inline fw-bold"/> Including Tax
                                            </span>
                                        </div>
                                        <field name="markup" class="border-bottom border-dark"/>
                                        <field name="id" invisible="1"/>
                                        <field name="has_active_taxes" invisible="1"/>
                                        <field name="sale_tax_ids" widget="many2many_tags" invisible="not has_active_taxes" class="border-bottom border-dark"/>
                                        <field name="purchase_tax_ids" widget="many2many_tags" invisible="not has_active_taxes" class="border-bottom border-dark"/>
                                        <field name="opening_stock" string="Opening Stock" invisible="id" class="border-bottom border-dark"/>
                                        <field name="opening_stock" string="On hand" invisible="not id" readonly="1" class="border-bottom border-dark"/>
                                        <field name="image_1920" widget="image" class="oe_avatar" options="{'preview_image': 'image_1920'}"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Advanced Pricing">
                                <field name="allow_advanced_pricing" invisible="1"/>
                                
                                <!-- Warning if disabled -->
                                <div invisible="allow_advanced_pricing" class="alert alert-info" role="alert" style="margin-top: 10px; margin-bottom: 20px;">
                                    <h4 class="alert-heading">Multi-UOM &amp; Advanced Pricing is Disabled</h4>
                                    <p>To use Wholesale and Retail prices, or to sell items in multiple units of measure (e.g. Boxes and Singles), please activate the <b>Allow Advanced Pricing &amp; Multi-UOM</b> setting.</p>
                                    <hr/>
                                    <p class="mb-0">Go to <b>Settings &gt; Stock</b> to activate this feature for your business.</p>
                                </div>
                                
                                <!-- Table if enabled -->
                                <group invisible="not allow_advanced_pricing">
                                    <field name="advanced_price_ids" nolabel="1">
                                        <list editable="bottom">
                                            <field name="pricelist_id" options="{'no_create': True}"/>
                                            <field name="uom_id" string="Unit of Measure" options="{'no_create': True}"/>
                                            <field name="qty_to_be_sold" string="Qty to be Sold"/>
                                            <field name="price"/>
                                        </list>
                                    </field>
                                </group>
                                
                                <group string="Other Pricing Settings">
                                    <group>
                                        <field name="discount_percentage" class="border-bottom border-dark"/>
                                        <field name="tax_percentage" class="border-bottom border-dark"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Other">
                                <group>
                                    <group>
                                        <field name="is_active" class="border-bottom border-dark"/>
                                        <field name="internal_notes" class="border-bottom border-dark"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Product Search View -->
        <record id="view_havanoposdesk_product_search" model="ir.ui.view">
            <field name="name">havanoposdesk.product.search</field>
            <field name="model">havanoposdesk.product</field>
            <field name="arch" type="xml">
                <search string="Search Products">
                    <field name="name"/>
                    <field name="item_code"/>
                    <field name="category_id"/>
                    <field name="opening_stock" string="On hand"/>
                    <separator/>
                    <filter string="In Stock" name="in_stock" domain="[('opening_stock', '&gt;', 0)]"/>
                    <filter string="Out of Stock" name="out_of_stock" domain="[('opening_stock', '&lt;=', 0)]"/>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_havanoposdesk_product" model="ir.actions.act_window">
            <field name="name">Products</field>
            <field name="res_model">havanoposdesk.product</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_havanoposdesk_product_search"/>
        </record>

        <!-- Menu Items for all Apps -->
        <menuitem id="menu_product_inventory" name="Products" parent="menu_inventory_master" action="action_havanoposdesk_product" sequence="10"/>
    </data>
</odoo>