<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_havanoposdesk_pricelist_tree" model="ir.ui.view">
            <field name="name">havanoposdesk.pricelist.tree</field>
            <field name="model">havanoposdesk.pricelist</field>
            <field name="arch" type="xml">
                <list string="Pricelists">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="type"/>
                </list>
            </field>
        </record>

        <record id="view_havanoposdesk_pricelist_form" model="ir.ui.view">
            <field name="name">havanoposdesk.pricelist.form</field>
            <field name="model">havanoposdesk.pricelist</field>
            <field name="arch" type="xml">
                <form string="Pricelist">
                    <sheet>
                        <group>
                            <group>
                                <field name="name" class="border-bottom border-dark"/>
                                <field name="code" class="border-bottom border-dark"/>
                                <field name="type" class="border-bottom border-dark"/>
                                <field name="tenant_id" invisible="1"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_havanoposdesk_pricelist" model="ir.actions.act_window">
            <field name="name">Pricelists</field>
            <field name="res_model">havanoposdesk.pricelist</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- Menu Items -->
        <menuitem id="menu_havanoposdesk_pricelist" name="Pricelists" parent="menu_inventory_master" action="action_havanoposdesk_pricelist" sequence="15"/>
    </data>
</odoo>
