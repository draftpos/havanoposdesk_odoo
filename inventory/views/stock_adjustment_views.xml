<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Stock Adjustment Form View -->
        <record id="view_havanoposdesk_stock_adjustment_form" model="ir.ui.view">
            <field name="name">havanoposdesk.stock.adjustment.form</field>
            <field name="model">havanoposdesk.stock.adjustment</field>
            <field name="arch" type="xml">
                <form string="Stock Adjustment">
                    <header>
                        <button name="action_post" string="Confirm" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                        <button name="action_cancel" string="Cancel" type="object" invisible="state != 'posted'"/>
                        <button name="action_draft" string="Reset to Draft" type="object" invisible="state != 'cancelled'"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,posted"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="store_id" options="{'no_create': True}" readonly="state != 'draft'" class="border-bottom border-dark"/>
                                <field name="currency_id" invisible="1"/>
                            </group>
                            <group>
                                <field name="allow_edit_date_time" readonly="state != 'draft'" class="border-bottom border-dark"/>
                                <field name="posting_date" readonly="not allow_edit_date_time or state != 'draft'" class="border-bottom border-dark"/>
                            </group>
                        </group>
                        <group>
                            <group>
                                <field name="fetch_all_data" readonly="state != 'draft'" class="border-bottom border-dark"/>
                            </group>
                            <group>
                                <field name="fetch_category_id" readonly="state != 'draft'" class="border-bottom border-dark"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Items">
                                <field name="line_ids" readonly="state != 'draft'">
                                    <list  editable="bottom">
                                        <field name="currency_id" column_invisible="True"/>
                                        <field name="product_id" domain="[('store_ids', 'in', parent.store_id)]" width="16%" optional="show"/>
                                        <field name="item_code" width="15%" optional="show"/>
                                        <field name="on_hand" width="16%" optional="show"/>
                                        <field name="counted" width="16%" optional="show"/>
                                        <field name="buying_price" width="16%" optional="show" widget="monetary"/>
                                        <field name="qty_difference" width="16%" sum="Total Qty Diff" optional="show"/>
                                        <field name="amount_difference" width="16%" sum="Total Amount Diff" optional="show" widget="monetary"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Stock Adjustment Tree View -->
        <record id="view_havanoposdesk_stock_adjustment_tree" model="ir.ui.view">
            <field name="name">havanoposdesk.stock.adjustment.tree</field>
            <field name="model">havanoposdesk.stock.adjustment</field>
            <field name="arch" type="xml">
                <list  string="Stock Adjustments">
                    <field name="currency_id" column_invisible="True"/>
                    <field  name="name" optional="show"/>
                    <field  name="store_id" optional="show"/>
                    <field  name="posting_date" optional="show"/>
                    <field  name="total_qty_difference" string="Variance" optional="show"/>
                    <field  name="total_amount_difference" string="Amount Difference" optional="show" widget="monetary"/>
                    <field  name="create_uid" string="Created By" optional="show"/>
                    <field  name="state" widget="badge" decoration-success="state == 'posted'" decoration-info="state == 'draft'" decoration-danger="state == 'cancelled'" optional="show"/>
                </list>
            </field>
        </record>

        <!-- Stock Adjustment Search View -->
        <record id="view_havanoposdesk_stock_adjustment_search" model="ir.ui.view">
            <field name="name">havanoposdesk.stock.adjustment.search</field>
            <field name="model">havanoposdesk.stock.adjustment</field>
            <field name="arch" type="xml">
                <search string="Search Stock Adjustments">
                    <field name="name"/>
                    <field name="store_id"/>
                    <field name="create_uid"/>
                    <field name="posting_date"/>
                    <filter string="Created On" name="filter_created_on" date="create_date"/>
                    <filter string="Created By" name="filter_created_by" domain="[('create_uid', '!=', False)]"/>
                    <filter string="Store" name="filter_store" domain="[('store_id', '!=', False)]"/>
                    <separator/>
                    <filter string="Today" name="today" domain="[('posting_date', '&gt;=', context_today().strftime('%Y-%m-%d 00:00:00')), ('posting_date', '&lt;=', context_today().strftime('%Y-%m-%d 23:59:59'))]"/>
                    <filter string="This Month" name="this_month" domain="[('posting_date', '&gt;=', context_today().replace(day=1).strftime('%Y-%m-%d 00:00:00')), ('posting_date', '&lt;=', (context_today().replace(day=1) + relativedelta(months=1, days=-1)).strftime('%Y-%m-%d 23:59:59'))]"/>
                    <group>
                        <filter string="Store" name="group_by_store" context="{'group_by': 'store_id'}"/>
                        <filter string="Created On" name="group_by_created_on" context="{'group_by': 'create_date:day'}"/>
                        <filter string="Created By" name="group_by_created_by" context="{'group_by': 'create_uid'}"/>
                        <filter string="Today" name="group_today" domain="[('posting_date', '&gt;=', context_today().strftime('%Y-%m-%d 00:00:00'))]" context="{'group_by': 'posting_date:day'}"/>
                        <filter string="This Month" name="group_month" domain="[('posting_date', '&gt;=', (context_today().replace(day=1)).strftime('%Y-%m-%d 00:00:00'))]" context="{'group_by': 'posting_date:month'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Stock Adjustment Action -->
        <record id="action_havanoposdesk_stock_adjustment" model="ir.actions.act_window">
            <field name="name">Stock Adjustment</field>
            <field name="res_model">havanoposdesk.stock.adjustment</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_havanoposdesk_stock_adjustment_search"/>
            <field name="context">{'search_default_today': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new Stock Adjustment
                </p>
            </field>
        </record>

        <!-- Menu Item -->
        <menuitem id="menu_inventory_stock_adjustment" 
                  name="Stock Adjustment" 
                  parent="menu_inventory_operations" 
                  action="action_havanoposdesk_stock_adjustment" 
                  sequence="10"/>
    </data>
</odoo>


