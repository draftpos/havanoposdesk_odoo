<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Stock Valuation -->
        <record id="view_havanoposdesk_stock_valuation_tree" model="ir.ui.view">
            <field name="name">havanoposdesk.stock.valuation.tree</field>
            <field name="model">havanoposdesk.stock.valuation</field>
            <field name="arch" type="xml">
                <list  string="Stock Valuation" create="0">
                    <field  name="product_id" optional="show"/>
                    <field  name="item_name" optional="show"/>
                    <field  name="item_code" optional="show"/>
                    <field  name="category_id" optional="show"/>
                    <field  name="store" optional="show"/>
                    <field  name="on_hand_qty" sum="Total Qty" optional="show"/>
                    <field  name="value_cost" sum="Total Cost Value" optional="show"/>
                    <field  name="value_selling" sum="Total Selling Value" optional="show"/>
                </list>
            </field>
        </record>

        <!-- Stock Ledger -->
        <record id="view_havanoposdesk_stock_ledger_tree" model="ir.ui.view">
            <field name="name">havanoposdesk.stock.ledger.tree</field>
            <field name="model">havanoposdesk.stock.ledger</field>
            <field name="arch" type="xml">
                <list  string="Stock Ledger" create="0">
                    <field  name="product_id" optional="show"/>
                    <field  name="item_name" optional="show"/>
                    <field  name="item_code" optional="show"/>
                    <field  name="uom_id" optional="show"/>
                    <field  name="in_qty" sum="Total In Qty" optional="show"/>
                    <field  name="out_qty" sum="Total Out Qty" optional="show"/>
                    <field  name="balance_qty" sum="Total Balance Qty" optional="show"/>
                    <field  name="store" optional="show"/>
                    <field  name="category_id" optional="show"/>
                    <field  name="in_value" sum="Total In Value" optional="show"/>
                    <field  name="out_value" sum="Total Out Value" optional="show"/>
                    <field  name="buying_price" optional="show"/>
                    <field  name="type" optional="show"/>
                    <field  name="doc_no" optional="show"/>
                    <field  name="balance_value" sum="Total Balance Value" optional="show"/>
                </list>
            </field>
        </record>

        <!-- Actions -->
        <record id="action_havanoposdesk_stock_valuation" model="ir.actions.act_window">
            <field name="name">Stock Valuation</field>
            <field name="res_model">havanoposdesk.stock.valuation</field>
            <field name="view_mode">list</field>
        </record>

        <record id="action_havanoposdesk_stock_ledger" model="ir.actions.act_window">
            <field name="name">Stock Ledger</field>
            <field name="res_model">havanoposdesk.stock.ledger</field>
            <field name="view_mode">list</field>
        </record>

        <!-- Menus -->
        <menuitem id="menu_inventory_stock_valuation" name="Stock Valuation" parent="menu_inventory_reports" action="action_havanoposdesk_stock_valuation" sequence="10"/>
        <menuitem id="menu_inventory_stock_ledger" name="Stock Ledger" parent="menu_inventory_reports" action="action_havanoposdesk_stock_ledger" sequence="20"/>
    </data>
</odoo>
