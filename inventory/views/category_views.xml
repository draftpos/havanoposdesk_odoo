<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_havanoposdesk_category_tree" model="ir.ui.view">
            <field name="name">havanoposdesk.category.tree</field>
            <field name="model">havanoposdesk.category</field>
            <field name="arch" type="xml">
                <list  string="Categories">
                    <field  name="name"/>
                    <field  name="store_ids" widget="many2many_tags"/>
                    <field  name="tenant_id" column_invisible="1"/>
                </list>
            </field>
        </record>

        <record id="view_havanoposdesk_category_form" model="ir.ui.view">
            <field name="name">havanoposdesk.category.form</field>
            <field name="model">havanoposdesk.category</field>
            <field name="arch" type="xml">
                <form string="Category">
                    <sheet>
                        <group>
                            <group>
                                <field name="name" string="Category Name" placeholder="e.g. Beverages" class="border-bottom border-dark"/>
                                <field name="tenant_id" invisible="1"/>
                            </group>
                            <group>
                                <field name="store_ids" widget="many2many_tags" class="border-bottom border-dark"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_havanoposdesk_category" model="ir.actions.act_window">
            <field name="name">Categories</field>
            <field name="res_model">havanoposdesk.category</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="menu_category_inventory" name="Categories" parent="menu_inventory_master" action="action_havanoposdesk_category" sequence="20"/>
    </data>
</odoo>
