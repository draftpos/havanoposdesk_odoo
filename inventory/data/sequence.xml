<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_havanoposdesk_product" model="ir.sequence">
            <field name="name">Product Item Code</field>
            <field name="code">havanoposdesk.product</field>
            <field name="prefix">PRD/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
        <record id="seq_havanoposdesk_sale" model="ir.sequence">
            <field name="name">Sale Reference</field>
            <field name="code">havanoposdesk.sale</field>
            <field name="prefix">SAL/</field>
            <field name="padding">6</field>
            <field name="company_id" eval="False"/>
        </record>
        <record id="seq_havanoposdesk_purchase" model="ir.sequence">
            <field name="name">Purchase Reference</field>
            <field name="code">havanoposdesk.purchase</field>
            <field name="prefix">PUR/</field>
            <field name="padding">6</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
