<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Category Sales Report Tree View -->
        <record id="view_category_sales_report_tree" model="ir.ui.view">
            <field name="name">havanoposdesk.category.sales.report.list</field>
            <field name="model">havanoposdesk.category.sales.report</field>
            <field name="arch" type="xml">
                <list string="Category Profitability" create="false" edit="false" delete="false">
                    <field name="date" optional="show"/>
                    <field name="category_id" optional="show"/>
                    <field name="store_id" optional="show"/>
                    <field name="qty" sum="Total Qty" optional="show"/>
                    <field name="cost_price" widget="monetary" optional="show"/>
                    <field name="selling_price" widget="monetary" optional="show"/>
                    <field name="total_sales" sum="Total Sales" widget="monetary" optional="show"/>
                    <field name="profit" sum="Total Profit" widget="monetary" decoration-danger="profit &lt; 0" decoration-success="profit &gt; 0" optional="show"/>
                    <field name="profit_margin" widget="percentage" decoration-danger="profit_margin &lt; 0" decoration-success="profit_margin &gt; 0" optional="show"/>
                </list>
            </field>
        </record>

        <!-- Category Sales Report Pivot View -->
        <record id="view_category_sales_report_pivot" model="ir.ui.view">
            <field name="name">havanoposdesk.category.sales.report.pivot</field>
            <field name="model">havanoposdesk.category.sales.report</field>
            <field name="arch" type="xml">
                <pivot string="Category Profitability" disable_linking="True">
                    <field name="category_id" type="row"/>
                    <field name="qty" type="measure"/>
                    <field name="total_sales" type="measure"/>
                    <field name="profit" type="measure"/>
                </pivot>
            </field>
        </record>

        <!-- Category Sales Report Search View -->
        <record id="view_category_sales_report_search" model="ir.ui.view">
            <field name="name">havanoposdesk.category.sales.report.search</field>
            <field name="model">havanoposdesk.category.sales.report</field>
            <field name="arch" type="xml">
                <search string="Search Category Profitability">
                    <field name="category_id"/>
                    <field name="store_id"/>
                    <separator/>
                    <filter string="Today" name="today" domain="[('date', '=', 'today')]"/>
                    <filter string="This Month" name="this_month" date="date" default_period="month"/>
                    <group>
                        <filter string="Store" name="group_by_store" context="{'group_by':'store_id'}"/>
                        <filter string="Date" name="group_by_date" context="{'group_by':'date'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action for Category Sales Report -->
        <record id="action_category_sales_report" model="ir.actions.act_window">
            <field name="name">Category Profitability</field>
            <field name="res_model">havanoposdesk.category.sales.report</field>
            <field name="view_mode">list,pivot</field>
            <field name="search_view_id" ref="view_category_sales_report_search"/>
            <field name="context">{'search_default_today': 1}</field>
        </record>

        <!-- Menu Item -->
        <menuitem id="menu_category_sales_report" name="Category Profitability" parent="menu_sales_reports" action="action_category_sales_report" sequence="20"/>
    </data>
</odoo>
