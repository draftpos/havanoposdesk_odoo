<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Terminal Sales Report Tree View -->
        <record id="view_terminal_sales_report_tree" model="ir.ui.view">
            <field name="name">havanoposdesk.terminal.sales.report.list</field>
            <field name="model">havanoposdesk.terminal.sales.report</field>
            <field name="arch" type="xml">
                <list string="Shop Profitability" create="false" edit="false" delete="false">
                    <field name="currency_id" column_invisible="True"/>
                    <field name="date" optional="show"/>
                    <field name="terminal_id" optional="show"/>
                    <field name="salesperson_id" optional="show"/>
                    <field name="store_id" optional="show"/>
                    <field name="cost_price" widget="monetary" optional="show"/>
                    <field name="selling_price" widget="monetary" optional="hide"/>
                    <field name="total_sales" sum="Total Sales" widget="monetary" optional="show"/>
                    <field name="profit" sum="Total Profit" widget="monetary" decoration-danger="profit &lt; 0" decoration-success="profit &gt; 0" optional="show"/>
                    <field name="profit_margin" widget="percentage" decoration-danger="profit_margin &lt; 0" decoration-success="profit_margin &gt; 0" optional="show"/>
                </list>
            </field>
        </record>

        <!-- Terminal Sales Report Pivot View -->
        <record id="view_terminal_sales_report_pivot" model="ir.ui.view">
            <field name="name">havanoposdesk.terminal.sales.report.pivot</field>
            <field name="model">havanoposdesk.terminal.sales.report</field>
            <field name="arch" type="xml">
                <pivot string="Shop Profitability" disable_linking="True">
                    <field name="terminal_id" type="row"/>
                    <field name="qty" type="measure"/>
                    <field name="total_sales" type="measure"/>
                    <field name="profit" type="measure"/>
                </pivot>
            </field>
        </record>

        <!-- Terminal Sales Report Search View -->
        <record id="view_terminal_sales_report_search" model="ir.ui.view">
            <field name="name">havanoposdesk.terminal.sales.report.search</field>
            <field name="model">havanoposdesk.terminal.sales.report</field>
            <field name="arch" type="xml">
                <search string="Search Shop Profitability">
                    <field name="terminal_id"/>
                    <field name="salesperson_id"/>
                    <field name="store_id"/>
                    <field name="create_uid"/>
                    <field name="create_date"/>
                    <separator/>
                    <filter string="Today" name="today" domain="[('date', '&gt;=', context_today().strftime('%Y-%m-%d 00:00:00')), ('date', '&lt;=', context_today().strftime('%Y-%m-%d 23:59:59'))]"/>
                    <filter string="This Month" name="this_month" domain="[('date', '&gt;=', context_today().replace(day=1).strftime('%Y-%m-%d 00:00:00')), ('date', '&lt;=', (context_today().replace(day=1) + relativedelta(months=1, days=-1)).strftime('%Y-%m-%d 23:59:59'))]"/>
                    <filter string="My Sales" name="my_sales" domain="[('salesperson_id', '=', uid)]"/>
                    <filter string="Terminal" name="filter_terminal" domain="[('terminal_id', '!=', False)]"/>
                    <filter string="Store" name="filter_store" domain="[('store_id', '!=', False)]"/>
                    <filter string="Created By" name="filter_created_by" domain="[('create_uid', '!=', False)]"/>
                    <filter string="Created On" name="filter_created_on" date="create_date"/>
                    <group>
                        <filter string="Terminal" name="group_by_terminal" context="{'group_by':'terminal_id'}"/>
                        <filter string="Store" name="group_by_store" context="{'group_by':'store_id'}"/>
                        <filter string="Date" name="group_by_date" context="{'group_by':'date'}"/>
                        <filter string="Created By" name="group_by_created_by" context="{'group_by':'create_uid'}"/>
                        <filter string="Created On" name="group_by_created_on" context="{'group_by':'create_date:day'}"/>
                        <filter string="Today" name="group_today" domain="[('date', '&gt;=', context_today().strftime('%Y-%m-%d 00:00:00'))]" context="{'group_by': 'date:day'}"/>
                        <filter string="This Month" name="group_month" domain="[('date', '&gt;=', (context_today().replace(day=1)).strftime('%Y-%m-%d 00:00:00'))]" context="{'group_by': 'date:month'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action for Terminal Sales Report -->
        <record id="action_terminal_sales_report" model="ir.actions.act_window">
            <field name="name">Shop Profitability</field>
            <field name="res_model">havanoposdesk.terminal.sales.report</field>
            <field name="view_mode">list,pivot</field>
            <field name="search_view_id" ref="view_terminal_sales_report_search"/>
            <field name="context">{'search_default_today': 1, 'search_default_my_sales': 1}</field>
        </record>

        <!-- Menu Item -->
        <menuitem id="menu_terminal_sales_report" name="Shop Profitability" parent="menu_sales_reports" action="action_terminal_sales_report" sequence="40"/>
    </data>
</odoo>

