<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Item Profitability Report Tree View -->
        <record id="view_item_profitability_report_tree" model="ir.ui.view">
            <field name="name">havanoposdesk.item.profitability.report.list</field>
            <field name="model">havanoposdesk.item.profitability.report</field>
            <field name="arch" type="xml">
                <list string="Item Profitability" create="false" edit="false" delete="false">
                    <field name="currency_id" column_invisible="True"/>
                    <field name="date" optional="show"/>
                    <field name="item_code" optional="hide"/>
                    <field name="name" string="Item Name" optional="show"/>
                    <field name="category_id" optional="show"/>
                    <field name="store_id" optional="show"/>
                    <field name="qty" string="Qty Sold" optional="show"/>
                    <field name="cost_price" string="Unit Buy Price" widget="monetary" optional="hide"/>
                    <field name="selling_price" string="Sell Price" widget="monetary" optional="hide"/>
                    <field name="total_buy_price" string="Buy Price" widget="monetary" optional="show"/>
                    <field name="total_sales" sum="Total Sales" widget="monetary" optional="show"/>
                    <field name="profit" sum="Total Profit" widget="monetary" decoration-danger="profit &lt; 0" decoration-success="profit &gt; 0" optional="show"/>
                    <field name="profit_margin" widget="percentage" decoration-danger="profit_margin &lt; 0" decoration-success="profit_margin &gt; 0" optional="show"/>
                </list>
            </field>
        </record>

        <!-- Item Profitability Report Pivot View -->
        <record id="view_item_profitability_report_pivot" model="ir.ui.view">
            <field name="name">havanoposdesk.item.profitability.report.pivot</field>
            <field name="model">havanoposdesk.item.profitability.report</field>
            <field name="arch" type="xml">
                <pivot string="Item Profitability" disable_linking="True">
                    <field name="category_id" type="row"/>
                    <field name="product_id" type="row"/>
                    <field name="qty" type="measure"/>
                    <field name="total_sales" type="measure"/>
                    <field name="profit" type="measure"/>
                </pivot>
            </field>
        </record>

        <!-- Item Profitability Report Search View -->
        <record id="view_item_profitability_report_search" model="ir.ui.view">
            <field name="name">havanoposdesk.item.profitability.report.search</field>
            <field name="model">havanoposdesk.item.profitability.report</field>
            <field name="arch" type="xml">
                <search string="Search Profitability">
                    <field name="name" string="Product"/>
                    <field name="item_code"/>
                    <field name="category_id"/>
                    <field name="store_id"/>
                    <field name="create_uid"/>
                    <field name="create_date"/>
                    <separator/>
                    <filter string="Today" name="today" domain="[('date', '&gt;=', context_today().strftime('%Y-%m-%d 00:00:00')), ('date', '&lt;=', context_today().strftime('%Y-%m-%d 23:59:59'))]"/>
                    <filter string="This Month" name="this_month" domain="[('date', '&gt;=', context_today().replace(day=1).strftime('%Y-%m-%d 00:00:00')), ('date', '&lt;=', (context_today().replace(day=1) + relativedelta(months=1, days=-1)).strftime('%Y-%m-%d 23:59:59'))]"/>
                    <filter string="Item Code" name="filter_item_code" domain="[('item_code', '!=', False)]"/>
                    <filter string="Category" name="filter_category" domain="[('category_id', '!=', False)]"/>
                    <filter string="Created On" name="filter_created_on" date="create_date"/>
                    <filter string="Created By" name="filter_created_by" domain="[('create_uid', '!=', False)]"/>
                    <group>
                        <filter string="Item Code" name="group_by_item_code" context="{'group_by':'item_code'}"/>
                        <filter string="Category" name="group_by_category" context="{'group_by':'category_id'}"/>
                        <filter string="Store" name="group_by_store" context="{'group_by':'store_id'}"/>
                        <filter string="Date" name="group_by_date" context="{'group_by':'date'}"/>
                        <filter string="Created On" name="group_by_created_on" context="{'group_by':'create_date:day'}"/>
                        <filter string="Created By" name="group_by_created_by" context="{'group_by':'create_uid'}"/>
                        <filter string="Today" name="group_today" domain="[('date', '&gt;=', context_today().strftime('%Y-%m-%d 00:00:00'))]" context="{'group_by': 'date:day'}"/>
                        <filter string="This Month" name="group_month" domain="[('date', '&gt;=', (context_today().replace(day=1)).strftime('%Y-%m-%d 00:00:00'))]" context="{'group_by': 'date:month'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action for Item Profitability Report -->
        <record id="action_item_profitability_report" model="ir.actions.act_window">
            <field name="name">Item Profitability</field>
            <field name="res_model">havanoposdesk.item.profitability.report</field>
            <field name="view_mode">list,pivot</field>
            <field name="search_view_id" ref="view_item_profitability_report_search"/>
            <field name="context">{'search_default_today': 1}</field>
        </record>

        <!-- Menu Item -->
        <menuitem id="menu_item_profitability_report" name="Item Profitability" parent="menu_sales_reports" action="action_item_profitability_report" sequence="10"/>
    </data>
</odoo>
