<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Customer Form View -->
        <record id="view_havanoposdesk_customer_form" model="ir.ui.view">
            <field name="name">havanoposdesk.customer.form</field>
            <field name="model">havanoposdesk.customer</field>
            <field name="arch" type="xml">
                <form string="Customer">
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" placeholder="e.g. John Doe" class="border-bottom border-dark"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="customer_type" class="border-bottom border-dark"/>
                                <field name="customer_group_id" class="border-bottom border-dark"/>
                                <field name="phone" class="border-bottom border-dark"/>
                                <field name="address" class="border-bottom border-dark"/>
                                <field name="city" class="border-bottom border-dark"/>
                                <field name="country" class="border-bottom border-dark"/>
                            </group>
                            <group>
                                <field name="balance" readonly="1" class="border-bottom border-dark"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Customer Tree View -->
        <record id="view_havanoposdesk_customer_tree" model="ir.ui.view">
            <field name="name">havanoposdesk.customer.tree</field>
            <field name="model">havanoposdesk.customer</field>
            <field name="arch" type="xml">
                <list  string="Customers">
                    <field  name="name" optional="show"/>
                    <field  name="phone" optional="show"/>
                    <field  name="address" optional="show"/>
                    <field  name="city" optional="show"/>
                    <field  name="country" optional="show"/>
                    <field  name="balance" optional="show"/>
                    <field  name="customer_type" optional="show"/>
                </list>
            </field>
        </record>

        <!-- Action -->
        <record id="action_havanoposdesk_customer" model="ir.actions.act_window">
            <field name="name">Customers</field>
            <field name="res_model">havanoposdesk.customer</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new Customer Record
                </p>
            </field>
        </record>

        <!-- Customer Group Form View -->
        <record id="view_havanoposdesk_customer_group_form" model="ir.ui.view">
            <field name="name">havanoposdesk.customer.group.form</field>
            <field name="model">havanoposdesk.customer.group</field>
            <field name="arch" type="xml">
                <form string="Customer Group">
                    <sheet>
                        <group>
                            <field name="name" class="border-bottom border-dark"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Customer Group Tree View -->
        <record id="view_havanoposdesk_customer_group_tree" model="ir.ui.view">
            <field name="name">havanoposdesk.customer.group.tree</field>
            <field name="model">havanoposdesk.customer.group</field>
            <field name="arch" type="xml">
                <list string="Customer Groups">
                    <field name="name"/>
                </list>
            </field>
        </record>

        <!-- Customer Group Action -->
        <record id="action_havanoposdesk_customer_group" model="ir.actions.act_window">
            <field name="name">Customer Groups</field>
            <field name="res_model">havanoposdesk.customer.group</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new Customer Group
                </p>
            </field>
        </record>

        <!-- Menu -->
        <menuitem id="menu_sales_customer" 
                  name="Customers" 
                  parent="menu_sales_master" 
                  action="action_havanoposdesk_customer" 
                  sequence="20"/>

        <menuitem id="menu_sales_customer_group" 
                  name="Customer Groups" 
                  parent="menu_sales_master" 
                  action="action_havanoposdesk_customer_group" 
                  sequence="30"/>
    </data>
</odoo>
