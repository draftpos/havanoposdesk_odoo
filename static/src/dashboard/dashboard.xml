<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="havanoposdesk_odoo.Dashboard" owl="1">
        <div class="havano-dashboard-container o_action">
            <div class="d-flex justify-content-between align-items-center mb-4 dashboard-header">
                <h2 class="m-0 text-dark fw-bolder d-none d-md-block">Dashboard</h2>
                
                <!-- Period Filter Dropdown -->
                <div class="dropdown">
                    <Dropdown>
                        <button class="btn bg-white border shadow-sm text-dark d-flex align-items-center rounded-2 px-3 py-2">
                            <i class="fa fa-calendar me-2 text-muted"></i>
                            <span t-esc="state.periodLabel"></span>
                        </button>
                        <t t-set-slot="content">
                            <DropdownItem onSelected="() => this.setPeriod('today', 'Today')">Today</DropdownItem>
                            <DropdownItem onSelected="() => this.setPeriod('yesterday', 'Yesterday')">Yesterday</DropdownItem>
                            <DropdownItem onSelected="() => this.setPeriod('this_week', 'This week')">This week</DropdownItem>
                            <DropdownItem onSelected="() => this.setPeriod('last_week', 'Last week')">Last week</DropdownItem>
                            <DropdownItem onSelected="() => this.setPeriod('this_month', 'This month')">This month</DropdownItem>
                            <DropdownItem onSelected="() => this.setPeriod('last_month', 'Last month')">Last month</DropdownItem>
                        </t>
                    </Dropdown>
                </div>
            </div>

            <!-- KPI Cards -->
            <div class="row g-3 mb-4">
                <div class="col-6 col-md-3">
                    <div class="card h-100 border-0 shadow-sm rounded-3">
                        <div class="card-body position-relative overflow-hidden">
                            <div class="top-indicator bg-primary"></div>
                            <h6 class="card-title text-muted fw-bold mb-2">Gross sales</h6>
                            <h3 class="card-text fw-bolder mb-3"><t t-esc="formatCurrency(state.kpis.gross_sales)"/></h3>
                            <small class="text-muted"><t t-esc="state.periodLabel"/></small>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="card h-100 border-0 shadow-sm rounded-3">
                        <div class="card-body position-relative overflow-hidden">
                            <div class="top-indicator bg-success"></div>
                            <h6 class="card-title text-muted fw-bold mb-2">Net sales</h6>
                            <h3 class="card-text fw-bolder mb-3"><t t-esc="formatCurrency(state.kpis.net_sales)"/></h3>
                            <small class="text-muted"><t t-esc="state.periodLabel"/></small>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="card h-100 border-0 shadow-sm rounded-3">
                        <div class="card-body position-relative overflow-hidden">
                            <div class="top-indicator bg-purple"></div>
                            <h6 class="card-title text-muted fw-bold mb-2">Cost of sales</h6>
                            <h3 class="card-text fw-bolder mb-3"><t t-esc="formatCurrency(state.kpis.cost_of_sales)"/></h3>
                            <small class="text-muted"><t t-esc="state.periodLabel"/></small>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="card h-100 border-0 shadow-sm rounded-3">
                        <div class="card-body position-relative overflow-hidden">
                            <div class="top-indicator bg-warning"></div>
                            <h6 class="card-title text-muted fw-bold mb-2">Gross profit</h6>
                            <h3 class="card-text fw-bolder mb-3"><t t-esc="formatCurrency(state.kpis.gross_profit)"/></h3>
                            <small class="text-muted"><t t-esc="state.periodLabel"/></small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sales Summary Chart -->
            <div class="card border-0 shadow-sm rounded-3 mb-4">
                <div class="card-body">
                    <h5 class="card-title fw-bolder text-dark mb-1">Sales summary</h5>
                    <small class="text-muted d-block mb-4"><t t-esc="state.periodLabel"/></small>
                    <div class="chart-container" style="position: relative; height:300px; width:100%">
                        <canvas t-ref="salesChart"></canvas>
                    </div>
                </div>
            </div>

            <!-- Bottom Row: Other KPIs and Stock Valuation Chart -->
            <div class="row g-3">
                <div class="col-12 col-md-4">
                    <div class="card border-0 shadow-sm rounded-3 h-100">
                        <div class="card-body border-bottom p-4">
                            <h6 class="card-title text-dark fw-bold mb-2">Discount</h6>
                            <h3 class="card-text fw-bolder mb-3">0.00</h3>
                            <small class="text-muted"><t t-esc="state.periodLabel"/></small>
                        </div>
                        <div class="card-body p-4">
                            <h6 class="card-title text-dark fw-bold mb-2">Cash refund</h6>
                            <h3 class="card-text fw-bolder mb-3">0.00</h3>
                            <small class="text-muted"><t t-esc="state.periodLabel"/></small>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-md-8">
                    <div class="card border-0 shadow-sm rounded-3 h-100">
                        <div class="card-body">
                            <h5 class="card-title fw-bolder text-dark mb-1">Stock valuation</h5>
                            <small class="text-muted d-block mb-4"><t t-esc="state.periodLabel"/></small>
                            <div class="chart-container" style="position: relative; height:300px; width:100%">
                                <canvas t-ref="stockChart"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Add a slight bottom padding for mobile so it doesn't stick to edge -->
            <div class="pb-4"></div>
        </div>
    </t>

</templates>
