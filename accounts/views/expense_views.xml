<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Expense List View -->
        <record id="view_havanoposdesk_expense_tree" model="ir.ui.view">
            <field name="name">havanoposdesk.expense.list</field>
            <field name="model">havanoposdesk.expense</field>
            <field name="arch" type="xml">
                <list string="Expense Posting" decoration-info="state == 'Draft'" decoration-success="state == 'Posted'">
                    <field name="name"/>
                    <field name="date"/>
                    <field name="supplier_id"/>
                    <field name="account_id"/>
                    <field name="amount" sum="Total Expenses"/>
                    <field name="is_paid" widget="boolean_toggle"/>
                    <field name="state" widget="badge" decoration-info="state == 'Draft'" decoration-success="state == 'Posted'"/>
                </list>
            </field>
        </record>

        <!-- Expense Form View -->
        <record id="view_havanoposdesk_expense_form" model="ir.ui.view">
            <field name="name">havanoposdesk.expense.form</field>
            <field name="model">havanoposdesk.expense</field>
            <field name="arch" type="xml">
                <form string="Expense Posting">
                    <header>
                        <button name="action_post" string="Post" type="object" class="oe_highlight" invisible="state != 'Draft'"/>
                        <field name="state" widget="statusbar" statusbar_visible="Draft,Posted"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="date" readonly="state != 'Draft'"/>
                                <field name="supplier_id" readonly="state != 'Draft'"/>
                                <field name="account_id" readonly="state != 'Draft'"/>
                                <field name="amount" readonly="state != 'Draft'"/>
                            </group>
                            <group>
                                <field name="is_paid" readonly="state != 'Draft'"/>
                                <field name="payment_account_id" invisible="not is_paid" required="is_paid" readonly="state != 'Draft'"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Description">
                                <field name="description" readonly="state != 'Draft'"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Expense Search View -->
        <record id="view_havanoposdesk_expense_search" model="ir.ui.view">
            <field name="name">havanoposdesk.expense.search</field>
            <field name="model">havanoposdesk.expense</field>
            <field name="arch" type="xml">
                <search string="Expense Posting">
                    <field name="name"/>
                    <field name="account_id"/>
                    <field name="date"/>
                    <filter string="Draft" name="draft" domain="[('state','=','Draft')]"/>
                    <filter string="Posted" name="posted" domain="[('state','=','Posted')]"/>
                    <separator/>
                    <filter string="Account" name="group_by_account" context="{'group_by':'account_id'}"/>
                    <filter string="Date" name="group_by_date" context="{'group_by':'date'}"/>
                    <filter string="Status" name="group_by_state" context="{'group_by':'state'}"/>
                </search>
            </field>
        </record>

        <!-- Action for Expenses -->
        <record id="action_havanoposdesk_expense" model="ir.actions.act_window">
            <field name="name">Expense Posting</field>
            <field name="res_model">havanoposdesk.expense</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_group_by_account': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new Expense Posting
                </p>
                <p>
                    Log your daily expenses here.
                </p>
            </field>
        </record>
    </data>
</odoo>
