<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>
        
        <record id="view_havanoposdesk_account_tree" model="ir.ui.view">
            <field name="name">havanoposdesk.account.list</field>
            <field name="model">havanoposdesk.account</field>
            <field name="arch" type="xml">
                <list string="Accounts">
                    <field name="name" />
                    <field name="type" />
                    <field name="currency_id" optional="show" invisible="type not in ['Cash', 'Bank']" />
                    <field name="balance" optional="show" />
                </list>
            </field>
        </record>

        
        <record id="view_havanoposdesk_account_form" model="ir.ui.view">
            <field name="name">havanoposdesk.account.form</field>
            <field name="model">havanoposdesk.account</field>
            <field name="arch" type="xml">
                <form string="Account">
                    <sheet>
                        <group>
                            <group>
                                <field name="name" />
                                <field name="type" />
                                <field name="currency_id" invisible="type not in ['Cash', 'Bank']" />
                                <field name="balance" />
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        
        <record id="view_havanoposdesk_account_search" model="ir.ui.view">
            <field name="name">havanoposdesk.account.search</field>
            <field name="model">havanoposdesk.account</field>
            <field name="arch" type="xml">
                <search string="Accounts">
                    <field name="name" />
                    <field name="type" />
                    <filter string="Expenses" name="filter_expense" domain="[('type','=','Expense')]" />
                    <filter string="Cash/Bank" name="filter_cash_bank" domain="[('type','in',['Cash','Bank'])]" />
                </search>
            </field>
        </record>

        
        <record id="action_havanoposdesk_account" model="ir.actions.act_window">
            <field name="name">Chart of Accounts</field>
            <field name="res_model">havanoposdesk.account</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new Account
                </p>
                <p>
                    Manage your Cash, Bank, and Expense accounts.
                </p>
            </field>
        </record>

        <record id="action_havanoposdesk_cash_balance_report" model="ir.actions.act_window">
            <field name="name">Cash Balance</field>
            <field name="res_model">havanoposdesk.account</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_filter_cash_bank': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No Cash or Bank accounts found.
                </p>
            </field>
        </record>

        <menuitem id="menu_accounts_list" name="Accounts" parent="menu_accounts_master" action="action_havanoposdesk_account" sequence="10" groups="havanoposdesk_odoo.group_tenant_admin,base.group_system" />
        <menuitem id="menu_accounts_cash_balance" name="Cash Balance" parent="menu_accounts_reports" action="action_havanoposdesk_cash_balance_report" sequence="20" />
        <menuitem id="menu_sales_cash_balance" name="Cash Balance" parent="menu_sales_reports" action="action_havanoposdesk_cash_balance_report" sequence="40" />
    </data>
</odoo>