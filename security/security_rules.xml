<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Tenant Model Isolation Rule -->
        <record id="rule_havano_tenant_isolation" model="ir.rule">
            <field name="name">Havano Tenant Isolation</field>
            <field name="model_id" ref="model_havanoposdesk_tenant"/>
            <field name="global" eval="True"/>
            <field name="domain_force">[] if user.havano_role == 'super_admin' else [('id', '=', user.tenant_id.id)]</field>
        </record>

        <!-- Category Model Isolation Rule -->
        <record id="rule_havano_category_isolation" model="ir.rule">
            <field name="name">Havano Category Isolation</field>
            <field name="model_id" ref="model_havanoposdesk_category"/>
            <field name="global" eval="True"/>
            <field name="domain_force">[] if user.havano_role == 'super_admin' else [('tenant_id', '=', user.tenant_id.id)]</field>
        </record>

        <!-- UOM Model Isolation Rule -->
        <record id="rule_havano_uom_isolation" model="ir.rule">
            <field name="name">Havano UOM Isolation</field>
            <field name="model_id" ref="model_havanoposdesk_uom"/>
            <field name="global" eval="True"/>
            <field name="domain_force">[] if user.havano_role == 'super_admin' else [('tenant_id', '=', user.tenant_id.id)]</field>
        </record>

        <!-- Shop Model Isolation Rule -->
        <record id="rule_havano_shop_isolation" model="ir.rule">
            <field name="name">Havano Shop Isolation</field>
            <field name="model_id" ref="model_havanoposdesk_shop"/>
            <field name="global" eval="True"/>
            <field name="domain_force">[] if user.havano_role == 'super_admin' else [('tenant_id', '=', user.tenant_id.id)] if user.havano_role == 'admin' else [('tenant_id', '=', user.tenant_id.id), ('id', 'in', user.shop_ids.ids)]</field>
        </record>

        <!-- Product Model Isolation Rule -->
        <record id="rule_havano_product_isolation" model="ir.rule">
            <field name="name">Havano Product Isolation</field>
            <field name="model_id" ref="model_havanoposdesk_product"/>
            <field name="global" eval="True"/>
            <field name="domain_force">[] if user.havano_role == 'super_admin' else [('tenant_id', '=', user.tenant_id.id)] if user.havano_role == 'admin' else [('tenant_id', '=', user.tenant_id.id), ('shop_id', 'in', user.shop_ids.ids)]</field>
        </record>

        <!-- Sale Model Isolation Rule -->
        <record id="rule_havano_sale_isolation" model="ir.rule">
            <field name="name">Havano Sale Isolation</field>
            <field name="model_id" ref="model_havanoposdesk_sale"/>
            <field name="global" eval="True"/>
            <field name="domain_force">[] if user.havano_role == 'super_admin' else [('tenant_id', '=', user.tenant_id.id)] if user.havano_role == 'admin' else [('tenant_id', '=', user.tenant_id.id), ('shop_id', 'in', user.shop_ids.ids)]</field>
        </record>

        <!-- Supplier Model Isolation Rule -->
        <record id="rule_havano_supplier_isolation" model="ir.rule">
            <field name="name">Havano Supplier Isolation</field>
            <field name="model_id" ref="model_havanoposdesk_supplier"/>
            <field name="global" eval="True"/>
            <field name="domain_force">[] if user.havano_role == 'super_admin' else [('tenant_id', '=', user.tenant_id.id)] if user.havano_role == 'admin' else [('tenant_id', '=', user.tenant_id.id), ('shop_id', 'in', user.shop_ids.ids)]</field>
        </record>

        <!-- POS Terminal Model Isolation Rule -->
        <record id="rule_havano_pos_terminal_isolation" model="ir.rule">
            <field name="name">Havano POS Terminal Isolation</field>
            <field name="model_id" ref="model_havanoposdesk_pos_terminal"/>
            <field name="global" eval="True"/>
            <field name="domain_force">[] if user.havano_role == 'super_admin' else [('tenant_id', '=', user.tenant_id.id)] if user.havano_role == 'admin' else [('tenant_id', '=', user.tenant_id.id), ('shop_id', 'in', user.shop_ids.ids)]</field>
        </record>

        <!-- Subscription Plan Model Isolation Rule (Allow Read for All Users) -->
        <record id="rule_havano_subscription_plan_isolation" model="ir.rule">
            <field name="name">Havano Subscription Plan Isolation</field>
            <field name="model_id" ref="model_havanoposdesk_subscription_plan"/>
            <field name="global" eval="True"/>
            <field name="domain_force">[]</field>
        </record>

        <!-- User Model Isolation Rule -->
        <record id="rule_havano_user_isolation" model="ir.rule">
            <field name="name">Havano User Isolation</field>
            <field name="model_id" ref="base.model_res_users"/>
            <field name="global" eval="True"/>
            <field name="domain_force">[] if user.havano_role == 'super_admin' or not user.tenant_id else [('tenant_id', '=', user.tenant_id.id)]</field>
        </record>    </data>
</odoo>
